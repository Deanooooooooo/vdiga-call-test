---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyCallBar from "../components/StickyCallBar.astro";
import { organizationSchema, breadcrumbSchema } from "../data/schema";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  path: string;
  schemas?: Record<string, unknown>[];
}

const { title, description, path, schemas = [] } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const canonical = `${site.url}${path}`;
const allSchemas = [
  organizationSchema(),
  breadcrumbSchema([
    { name: "Начало", href: "/" },
    ...(path === "/" ? [] : [{ name: title.replace(` | ${site.brand}`, ""), href: path }]),
  ]),
  ...schemas,
];
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <meta name="author" content={site.author.name} />
    <meta name="theme-color" content="#0b1210" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="bg_BG" />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href={`${basePath}favicon.svg`} type="image/svg+xml" />
    {allSchemas.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />)}
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <main>
        <slot />
      </main>
      <StickyCallBar />
      <Footer />
    </div>
  </body>
</html>
