---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyCallBar from "../components/StickyCallBar.astro";
import { organizationSchema, breadcrumbSchema, websiteSchema } from "../data/schema";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  path: string;
  pageClass?: string;
  schemas?: Record<string, unknown>[];
  image?: string;
  imageAlt?: string;
  ogType?: "website" | "article";
}

const { title, description, path, pageClass, schemas = [], image, imageAlt, ogType = "website" } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const canonical = `${site.url}${path}`;
const resolvedImage = image ?? "/assets/vdiga-og-default-v2.png";
const resolvedImageAlt = imageAlt ?? "Vdiga AI рецепционист на български";
const socialImage = `${site.url}${resolvedImage}`;
const socialImageType = resolvedImage.endsWith(".jpg") || resolvedImage.endsWith(".jpeg")
  ? "image/jpeg"
  : resolvedImage.endsWith(".webp")
    ? "image/webp"
    : "image/png";
const allSchemas = [
  organizationSchema(),
  websiteSchema(),
  breadcrumbSchema([
    { name: "Начало", href: "/" },
    ...(path === "/" ? [] : [{ name: title.replace(` | ${site.brand}`, ""), href: path }]),
  ]),
  ...schemas,
];
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:locale" content="bg_BG" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content={socialImageType} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={resolvedImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={resolvedImageAlt} />
    <link rel="icon" href={`${basePath}favicon.jpg?v=6fa21b71`} type="image/jpeg" />
    {allSchemas.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />)}
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <main class={pageClass}>
        <slot />
      </main>
      <StickyCallBar />
      <Footer />
    </div>
    <audio id="site-demo-audio" preload="metadata" src={`${basePath}assets/vdiga-mdsolution-demo-v35.mp3`} hidden></audio>
    <script>
      document.addEventListener("click", (event) => {
        const link = (event.target as Element).closest<HTMLAnchorElement>('a[href*="#"]');
        if (!link) return;

        const url = new URL(link.href, window.location.href);
        if (url.pathname !== window.location.pathname || !url.hash) return;

        const target = document.querySelector<HTMLElement>(url.hash);
        if (!target) return;

        event.preventDefault();
        const header = document.querySelector<HTMLElement>(".site-top");
        const headerHeight = header?.offsetHeight || 0;
        const top = target.getBoundingClientRect().top + window.scrollY - headerHeight - 16;
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        window.scrollTo({ top: window.scrollY, behavior: "auto" });
        requestAnimationFrame(() => {
          window.scrollTo({ top, behavior: reduceMotion ? "auto" : "smooth" });
        });
      });

      document.querySelectorAll<HTMLElement>("[data-play-demo]").forEach((trigger) => {
        const fallbackAudio = document.querySelector<HTMLAudioElement>("#site-demo-audio");
        const visibleAudio = document.querySelector<HTMLAudioElement>(".demo-audio");
        const audio = visibleAudio || fallbackAudio;
        if (!audio) return;

        const originalLabel = trigger.textContent?.trim() || "Чуйте как звучи";

        trigger.addEventListener("click", async (event) => {
          event.preventDefault();

          document.querySelectorAll("audio").forEach((otherAudio) => {
            if (otherAudio !== audio) otherAudio.pause();
          });

          if (audio.paused) {
            await audio.play();
          } else {
            audio.pause();
          }
        });

        audio.addEventListener("play", () => {
          trigger.setAttribute("aria-pressed", "true");
          trigger.textContent = "Спрете записа";
        });

        audio.addEventListener("pause", () => {
          trigger.setAttribute("aria-pressed", "false");
          trigger.textContent = originalLabel;
        });
      });
    </script>
  </body>
</html>
