---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyCallBar from "../components/StickyCallBar.astro";
import { organizationSchema, breadcrumbSchema } from "../data/schema";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  path: string;
  schemas?: Record<string, unknown>[];
}

const { title, description, path, schemas = [] } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const canonical = `${site.url}${path}`;
const allSchemas = [
  organizationSchema(),
  breadcrumbSchema([
    { name: "Начало", href: "/" },
    ...(path === "/" ? [] : [{ name: title.replace(` | ${site.brand}`, ""), href: path }]),
  ]),
  ...schemas,
];
---

<!doctype html>
<html lang="bg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={`${basePath}favicon.jpg?v=6fa21b71`} type="image/jpeg" />
    {allSchemas.map((schema) => <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />)}
  </head>
  <body>
    <div class="page-shell">
      <Header />
      <main>
        <slot />
      </main>
      <StickyCallBar />
      <Footer />
    </div>
    <script>
      document.addEventListener("click", (event) => {
        const link = (event.target as Element).closest<HTMLAnchorElement>('a[href*="#"]');
        if (!link) return;

        const url = new URL(link.href, window.location.href);
        if (url.pathname !== window.location.pathname || !url.hash) return;

        const target = document.querySelector<HTMLElement>(url.hash);
        if (!target) return;

        event.preventDefault();
        const header = document.querySelector<HTMLElement>(".site-top");
        const headerHeight = header?.offsetHeight || 0;
        const top = target.getBoundingClientRect().top + window.scrollY - headerHeight - 16;
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        window.scrollTo({ top: window.scrollY, behavior: "auto" });
        requestAnimationFrame(() => {
          window.scrollTo({ top, behavior: reduceMotion ? "auto" : "smooth" });
        });
      });
    </script>
  </body>
</html>
