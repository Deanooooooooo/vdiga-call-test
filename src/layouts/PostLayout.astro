---
import BaseLayout from "./BaseLayout.astro";
import { site } from "../data/site";
import { articleSchema } from "../data/schema";
import { authorPath, getAuthor } from "../data/authors";

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  answer: string;
  path: string;
  eyebrow?: string;
  datePublished: string;
  dateModified: string;
  schemas?: Record<string, unknown>[];
  image: string;
  imageAlt: string;
  authorSlug?: string;
}

const {
  title,
  seoTitle,
  description,
  answer,
  path,
  eyebrow = "Ръководство",
  datePublished,
  dateModified,
  schemas = [],
  image,
  imageAlt,
  authorSlug = site.author.slug,
} = Astro.props;

const author = getAuthor(authorSlug) ?? site.author;
const authorUrl = authorPath(author.slug);

const formatDate = (value: string) =>
  new Intl.DateTimeFormat("bg-BG", { day: "numeric", month: "long", year: "numeric" }).format(
    new Date(`${value}T12:00:00+03:00`),
  );
---

<BaseLayout
  title={`${seoTitle ?? title} | ${site.brand}`}
  description={description}
  path={path}
  pageClass="post-page"
  ogType="article"
  image={image}
  imageAlt={imageAlt}
  schemas={[
    articleSchema({ headline: title, description, path, datePublished, dateModified, author, image }),
    ...schemas,
  ]}
>
  <article>
    <header class="post-header">
      <div class="post-container">
        <p class="eyebrow">{eyebrow}</p>
        <h1 class:list={{ "post-title-long": title.length > 45 }}>{title}</h1>
        <p class="answer-block">{answer}</p>
        <div class="post-byline" aria-label="Автор и дата на статията">
          <a class="post-byline-photo" href={authorUrl} rel="author" aria-label={`Профил на ${author.name}`}>
            <img src={author.image} width="720" height="720" alt={author.name} />
          </a>
          <div>
            <a class="post-byline-name" href={authorUrl} rel="author">{author.name}</a>
            <p class="post-byline-role">{author.role}</p>
            <p class="post-meta">
              <span>Публикувано на <time datetime={datePublished}>{formatDate(datePublished)}</time></span>
              {dateModified !== datePublished && (
                <><span aria-hidden="true">·</span><span>Обновено на <time datetime={dateModified}>{formatDate(dateModified)}</time></span></>
              )}
            </p>
          </div>
        </div>
        <figure class="post-featured-image">
          <img
            src={image}
            width="1200"
            height="630"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            alt={imageAlt}
          />
        </figure>
      </div>
    </header>

    <div class="post-container post-body">
      <slot />
    </div>

    <footer class="post-container post-author">
      <div class="post-author-head">
        <img class="avatar" src={author.image} width="720" height="720" loading="lazy" alt={author.name} />
        <div>
          <p class="post-author-label">За автора</p>
          <h2><a href={authorUrl} rel="author">{author.name}</a></h2>
          <p class="post-author-role">{author.role}</p>
        </div>
      </div>
      <p class="post-author-bio">{author.bio}</p>
      <a class="post-author-link" href={authorUrl}>Вижте профила и всички публикации →</a>
    </footer>
  </article>
</BaseLayout>
