---
import BaseLayout from "../layouts/BaseLayout.astro";
import PricingCards from "../components/PricingCards.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { articleSchema, faqSchema, productSchema } from "../data/schema";

const faqs = [
  {
    question: "Цените с ДДС ли са?",
    answer:
      "Цените на тази страница са без ДДС. Преди първа фактура Vdiga показва плана, включените функции и сумата с ДДС.",
  },
  {
    question: "Има ли договор?",
    answer:
      "Не. Моделът е месечен абонамент без дълъг договор. Ако Vdiga не носи стойност, спирате след текущия месец.",
  },
  {
    question: "Има ли такса за настройка?",
    answer:
      "Да. Първоначалната настройка е 150-250 евро според календара, FAQ базата и правилата за прехвърляне.",
  },
  {
    question: "Как се казва услугата на английски?",
    answer:
      "Английските термини са AI receptionist, AI answering service и voice AI assistant. На български Vdiga използва AI рецепционист.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="AI рецепционист цена — от 75 евро | Vdiga"
  description="Цени за AI рецепционист Vdiga: 75-100 евро, 150 евро и 200-250 евро/месец според обема и функциите."
  path="/tseni"
  schemas={[faqSchema(faqs), productSchema(), articleSchema("AI рецепционист цена — Vdiga", "/tseni", "Ориентировъчни цени за AI рецепционист на български език.")]}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">AI рецепционист цена</p>
      <h1>Цени — AI рецепционист от 75 евро/месец.</h1>
      <p class="answer-block">
        Към юли 2026 г. Vdiga струва от 75 евро/месец без ДДС. Основният план е 150 евро/месец и включва 24/7 отговор, записване на часове и обобщение след разговор.
      </p>
      <p class="lead">
        Плащате за телефон, който вдига. Не плащате за човек, който чака телефонът да звънне.
      </p>
      <div class="button-row hero-actions">
        <a class="btn btn-primary" href={href("/demo")}>Първо чуйте демото</a>
        <a class="btn btn-secondary" href="#plans">Вижте плановете</a>
      </div>
    </div>
  </section>

  <section class="section band" id="plans">
    <div class="container">
      <PricingCards />
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Какво не плащате?</p>
        <h2>Какво не плащате?</h2>
        <ul class="split-list">
          <li>Не плащате заплата, осигуровки и отпуск за рецепционист.</li>
          <li>Не губите входящи обаждания извън работно време.</li>
          <li>Не подписвате дълъг договор за първия тест.</li>
        </ul>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Разход</th>
              <th>Човешки рецепционист</th>
              <th>Vdiga</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Месечен разход</td>
              <td>заплата, осигуровки и отпуск</td>
              <td>от 75 евро/месец</td>
            </tr>
            <tr>
              <td>Работно време</td>
              <td>ограничено по график</td>
              <td>24/7 за входящи обаждания</td>
            </tr>
            <tr>
              <td>Сложни случаи</td>
              <td>решават се от екипа</td>
              <td>прехвърлят се към вас</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Въпроси за плащане</p>
        <h2>Какво се уточнява преди първата фактура?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Първо чуйте гласа. После гледайте цената." text="Ако разговорът звучи нормално, планът от 75 евро/месец става лесен за сравнение." />
</BaseLayout>
