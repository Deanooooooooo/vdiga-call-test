---
import BaseLayout from "../layouts/BaseLayout.astro";
import PricingCards from "../components/PricingCards.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import ArticleMeta from "../components/ArticleMeta.astro";
import { articleSchema, faqSchema, productSchema } from "../data/schema";
import { contentPageByPath } from "../data/content-pages";

const faqs = [
  {
    question: "Цените с ДДС ли са?",
    answer:
      "Цените на тази страница са без ДДС. Преди първа фактура виждате плана, включените функции и крайната сума с ДДС.",
  },
  {
    question: "Има ли договор?",
    answer:
      "Не. Моделът е месечен абонамент. Ако Vdiga не носи стойност, спирате след текущия месец.",
  },
  {
    question: "Има ли такса за настройка?",
    answer:
      "Да. Първоначалната настройка е 150-250 евро според календара, FAQ базата и правилата за пренасочване.",
  },
  {
    question: "Как се казва услугата на английски?",
    answer:
      "Английските термини са AI receptionist, AI answering service и voice AI assistant. На български използваме AI рецепционист.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
const page = contentPageByPath["/tseni"];
---

<BaseLayout
  title="AI рецепционист цена — от 75 евро | Vdiga"
  description="AI рецепционист цена: 75, 150 или 200-250 евро/месец без ДДС. Вижте кой план пасва на обажданията ви."
  path="/tseni"
  schemas={[faqSchema(faqs), productSchema(), articleSchema("AI рецепционист цена — Vdiga", "/tseni", "Ориентировъчни цени за AI рецепционист на български език.", page)]}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">AI рецепционист цена</p>
      <h1>Цени — AI рецепционист от 75 евро/месец.</h1>
      <p class="answer-block">
        Vdiga има три плана без ДДС: 75 евро, 150 евро и 200-250 евро/месец. Основният план включва отговор на входящи обаждания, записване на часове и кратко обобщение след разговора.
      </p>
      <p class="lead">
        Плащате за обаждания, които стигат до резултат. Не плащате за човек, който чака телефонът да звънне.
      </p>
      <ArticleMeta datePublished={page.datePublished} dateModified={page.dateModified} />
      <div class="button-row hero-actions">
        <a class="btn btn-primary" href={href("/demo")}>Чуйте разговор</a>
        <a class="btn btn-secondary" href="#plans">Вижте планове</a>
      </div>
    </div>
  </section>

  <section class="section band" id="plans">
    <div class="container">
      <PricingCards />
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">без скрити разходи</p>
        <h2>Какво не плащате?</h2>
        <ul class="split-list">
          <li>Не плащате заплата, осигуровки и отпуск за рецепционист.</li>
          <li>Не губите входящи обаждания извън работно време.</li>
          <li>Не подписвате договор, който ви държи насила.</li>
        </ul>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Разход</th>
              <th>Човешки рецепционист</th>
              <th>Vdiga</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Месечен разход</td>
              <td>заплата, осигуровки и отпуск</td>
              <td>от 75 евро/месец</td>
            </tr>
            <tr>
              <td>Работно време</td>
              <td>ограничено по график</td>
              <td>24/7 за входящи обаждания</td>
            </tr>
            <tr>
              <td>Сложни случаи</td>
              <td>решават се от екипа</td>
              <td>пренасочват се към вас</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">преди фактура</p>
        <h2>Какво се уточнява преди първата фактура?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Първо чуйте гласа. После гледайте цената." text="Ако разговорът звучи нормално, плановете стават лесни за сравнение." />
</BaseLayout>
