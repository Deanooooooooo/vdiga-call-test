---
import BaseLayout from "../layouts/BaseLayout.astro";
import PricingCards from "../components/PricingCards.astro";
import OnboardingForm from "../components/OnboardingForm.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { articleSchema, faqSchema, productSchema } from "../data/schema";

const faqs = [
  {
    question: "Цените с ДДС ли са?",
    answer:
      "Цените на тази страница са без ДДС. Преди първа фактура виждате плана, включените функции и крайната сума с ДДС.",
  },
  {
    question: "Има ли договор?",
    answer:
      "Не ви обвързваме с дългосрочен договор. Можете да изберете месечно плащане или годишно плащане с два безплатни месеца.",
  },
  {
    question: "Кой план е подходящ за моя бизнес?",
    answer:
      "Старт е за пропуснатите обаждания и по-малък месечен обем. Бизнес е за ежедневни входящи разговори. При над 500 минути или повече от три линии подготвяме индивидуална оферта.",
  },
  {
    question: "Какво уточняваме преди да започнете?",
    answer:
      "Разглеждаме кога изпускате обаждания, за какво звънят клиентите, колко линии са нужни и какво трябва да прави Vdiga. Получавате конкретно предложение преди да решите.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="Цени за AI рецепционист — от 97 евро | Vdiga"
  description="Планове за AI рецепционист от 97 евро/месец без ДДС. Изберете 120, 500 или над 500 минути входящи разговори."
  path="/tseni"
  schemas={[faqSchema(faqs), productSchema(), articleSchema("AI рецепционист цена — Vdiga", "/tseni", "Ориентировъчни цени за AI рецепционист на български език.")]}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">ясна цена според разговорите</p>
      <h1>Всеки пропуснат клиент струва повече от едно вдигнато обаждане.</h1>
      <p class="answer-block">
        Плановете на Vdiga започват от 97 €/месец за 120 минути входящи разговори. За ежедневни обаждания план Бизнес включва 500 минути за 297 €/месец. При по-голям обем получавате индивидуална оферта.
      </p>
      <p class="lead">
        Vdiga отговаря, когато вие не можете, записва какво иска клиентът и ви оставя ясен резултат след разговора. Избирате план според реалния си обем, не според броя служители.
      </p>
      <div class="button-row hero-actions">
        <a class="btn btn-primary" href={href("/demo")}>Чуйте разговор</a>
        <a class="btn btn-secondary" href="#plans">Вижте планове</a>
      </div>
    </div>
  </section>

  <section class="section band" id="plans">
    <div class="container">
      <div class="pricing-heading">
        <div>
          <p class="eyebrow">изберете според входящите минути</p>
          <h2>Колко обаждания искате Vdiga да поема?</h2>
        </div>
        <p>Ако не знаете точния си обем, не е проблем. Ще го изчислим заедно и ще ви насочим към най-разумния план.</p>
      </div>
      <PricingCards />
      <OnboardingForm />
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">плащате за покритие, не за чакане</p>
        <h2>Телефонът е поет, без да назначавате още един човек.</h2>
        <ul class="split-list">
          <li>Без заплата, осигуровки, отпуски и покриване на смени.</li>
          <li>До 3 телефонни линии в плановете Старт и Бизнес.</li>
          <li>3+ линии и индивидуален обем при по-голяма натовареност.</li>
        </ul>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Разход</th>
              <th>Човешки рецепционист</th>
              <th>Vdiga</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Месечен разход</td>
              <td>заплата, осигуровки и отпуск</td>
              <td>от 75 евро/месец</td>
            </tr>
            <tr>
              <td>Работно време</td>
              <td>ограничено по график</td>
              <td>24/7 за входящи обаждания</td>
            </tr>
            <tr>
              <td>Сложни случаи</td>
              <td>решават се от екипа</td>
              <td>пренасочват се към вас</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">преди да решите</p>
        <h2>Всичко важно за цената, без дребен шрифт.</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Цената има смисъл само ако разговорът звучи добре." text="Чуйте как Vdiga приема реално клиентско обаждане на български." buttonLabel="Чуйте примерен разговор" buttonHref={href("/demo")} />
</BaseLayout>
