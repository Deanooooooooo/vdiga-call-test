---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { articleSchema, faqSchema } from "../data/schema";

const faqs = [
  {
    question: "Колко време отнема настройката?",
    answer:
      "Целта е първият тестов AI рецепционист да се подготвя до 10 минути след подаване на сайт, Google профил или Facebook страница.",
  },
  {
    question: "С какъв календар работи v1?",
    answer:
      "Първата версия работи най-чисто с Cal.com API. Така свободните часове се проверяват без тежка настройка за всеки клиент.",
  },
  {
    question: "Какво става при спешен случай?",
    answer:
      "Vdiga следва вашите правила. При спешен или неясен случай AI асистентът прехвърля, взема съобщение или маркира разговора за човешка реакция.",
  },
  {
    question: "Как се казва това на английски?",
    answer:
      "Най-близките английски термини са AI receptionist, voice AI assistant и AI answering service.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="Как работи AI рецепционист — Vdiga"
  description="Как работи Vdiga: приемане на обаждане, проверка на свободни часове, записване, SMS и обобщение към собственика."
  path="/kak-raboti"
  schemas={[faqSchema(faqs), articleSchema("Как работи AI рецепционист — Vdiga", "/kak-raboti", "Стъпка по стъпка как AI рецепционист отговаря и записва часове.")]}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Как работи AI рецепционист</p>
      <h1>Как работи AI рецепционистът при входящо обаждане?</h1>
      <p class="answer-block">
        Към юли 2026 г. Vdiga приема входящото обаждане, проверява правилата ви, записва час в календар и праща обобщение. AI (изкуствен интелект) рецепционистът покрива моментите, в които никой не може да вдигне.
      </p>
      <p class="lead">
        Не учите нова система. Подавате публичната информация, проверявате тестовите разговори и включвате реалния номер след одобрение.
      </p>
      <div class="button-row hero-actions">
        <a class="btn btn-primary" href={href("/demo")}>Чуйте демото</a>
        <a class="btn btn-secondary" href={href("/tseni")}>Вижте плановете</a>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <p class="eyebrow">Поток</p>
      <h2>Какво се случва при едно входящо обаждане?</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Стъпка</th>
              <th>Какво прави Vdiga</th>
              <th>Какво виждате вие</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>1. Отговор</td>
              <td>Вдига телефона и се представя като AI асистент.</td>
              <td>Няма пропуснато първо обаждане.</td>
            </tr>
            <tr>
              <td>2. Уточнение</td>
              <td>Пита за услуга, спешност, име и удобен час.</td>
              <td>Получавате чиста информация, не бележки на ръка.</td>
            </tr>
            <tr>
              <td>3. Календар</td>
              <td>Проверява свободни часове според правилата.</td>
              <td>Календарът остава източникът на истината.</td>
            </tr>
            <tr>
              <td>4. Обобщение</td>
              <td>Праща кратък запис на резултата след разговора.</td>
              <td>Виждате какво е станало, без да слушате целия разговор.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Настройка</p>
        <h2>Как Vdiga разбира вашия бизнес?</h2>
        <p>
          Първата настройка не започва от празен чат. Vdiga използва сайта, Google профила или Facebook страницата ви, за да вземе услуги, работно време, адрес и правила.
        </p>
      </div>
      <div>
        <ol class="split-list">
          <li>Подавате сайт, Google профил или Facebook страница.</li>
          <li>Системата създава профил, FAQ база и правила за прехвърляне.</li>
          <li>Пускат се 3 тестови разговора преди реален трафик.</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <p class="eyebrow">Интеграции</p>
      <h2>Кои части влизат в първата версия?</h2>
      <div class="grid-3">
        <article class="feature">
          <h3>Гласов слой</h3>
          <p>Разговорът минава през готова гласова AI услуга. Vdiga не строи глас в реално време от нулата.</p>
        </article>
        <article class="feature">
          <h3>Twilio</h3>
          <p>Телефонният слой минава през Twilio и български номер, когато номерът е готов за публичен тест.</p>
        </article>
        <article class="feature">
          <h3>Cal.com</h3>
          <p>Свободните часове се проверяват през Cal.com API. Календарът остава източникът на истината.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Чести въпроси</p>
        <h2>Какво пита собственикът преди настройка?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Първо работещ разговор. После реални клиенти." text="Vdiga трябва да мине теста на гласа, календара и прехвърлянето преди входящи обаждания от клиенти." />
</BaseLayout>
