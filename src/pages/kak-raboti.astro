---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductVisual from "../components/ProductVisual.astro";
import OnboardingForm from "../components/OnboardingForm.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { faqSchema, serviceSchema } from "../data/schema";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;

const faqs = [
  {
    question: "Трябва ли да сменя телефонния си номер?",
    answer:
      "Не е задължително. Първо проверяваме как приемате обажданията си сега, а след това настройваме кога и кои разговори да поема Vdiga.",
  },
  {
    question: "Как Vdiga знае какво да каже?",
    answer:
      "Преди включването одобрявате информацията за услугите, цените, работното време и честите въпроси. Посочвате и случаите, в които разговорът трябва да бъде прехвърлен към човек.",
  },
  {
    question: "Може ли да записва часове?",
    answer:
      "Да. След като свържем календара, Vdiga проверява свободните часове, предлага подходящ вариант и записва избрания час.",
  },
  {
    question: "Какво става, ако разговорът е сложен или спешен?",
    answer:
      "Vdiga следва правилата, които сте задали: прехвърля разговора, взема съобщение или ви уведомява, че случаят е спешен.",
  },
  {
    question: "Какво получавам след разговора?",
    answer:
      "Получавате името и телефона на клиента, причината за обаждането, какво е уговорено и дали се очаква действие от вас.",
  },
];
---

<BaseLayout
  title="Как работи AI рецепционистът на Vdiga?"
  description="Вижте как Vdiga отговаря на български, записва часове, приема съобщения и ви изпраща резултата след всяко обаждане."
  path="/kak-raboti/"
  pageClass="how-page"
  image="/assets/vdiga-og-kak-raboti.png"
  imageAlt="Как работи AI рецепционистът Vdiga в четири стъпки"
  schemas={[faqSchema(faqs), serviceSchema("AI рецепционистът на Vdiga", "/kak-raboti/", "Vdiga отговаря на входящи обаждания на български, записва часове и изпраща кратко обобщение след разговора.")]}
>
  <section class="hero how-hero">
    <div class="container">
      <p class="eyebrow">от първото „ало“ до записания час</p>
      <h1>Как работи AI рецепционистът на Vdiga?</h1>
      <p class="answer-block">
        Vdiga е AI рецепционист за входящи обаждания. Отговаря на български, разбира какво иска клиентът, записва час или приема съобщение. След разговора получавате кой се е обадил, какво е поискал и какво е уговорено.
      </p>
      <p class="lead">
        Вие задавате услугите, работното време и случаите, в които разговорът трябва да стигне до човек.
      </p>
      <div class="button-row hero-actions">
        <button class="btn btn-primary" type="button" data-play-demo aria-pressed="false">Чуйте демото</button>
        <a class="btn btn-secondary" href="#nastroyka">Как се настройва</a>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">какво се случва при всяко обаждане</p>
          <h2>От „ало“ до записан час — без да прекъсвате работата си.</h2>
        </div>
        <p>Клиентът говори нормално. Vdiga задава нужните въпроси и приключва разговора със записан час, приета заявка или съобщение.</p>
      </div>
      <div class="how-flow">
        <article>
          <span>01</span>
          <h3>Отговаря от името на бизнеса ви</h3>
          <p>Поздравява клиента, представя се като AI асистент и пита с какво може да помогне.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Разбира причината за обаждането</h3>
          <p>Задава кратки въпроси за услугата, предпочитания ден, часа или адреса.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Записва час или приема заявката</h3>
          <p>Проверява графика, записва час, приема съобщение или прехвърля разговора.</p>
        </article>
        <article>
          <span>04</span>
          <h3>Изпраща ви резултата</h3>
          <p>Получавате името и телефона на клиента, причината за обаждането и следващата стъпка.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section how-proof-section">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">веднага след разговора</p>
          <h2>Знаете какво е уговорено, без да слушате запис.</h2>
        </div>
        <p>Получавате кратко обобщение и веднага виждате дали клиентът очаква нещо от вас.</p>
      </div>
      <ProductVisual />
    </div>
  </section>

  <section class="section band" id="nastroyka">
    <div class="container how-setup">
      <div class="how-setup-copy">
        <p class="eyebrow">настройка според начина ви на работа</p>
        <h2>Настройваме услугите, цените, графика и правилата за прехвърляне.</h2>
        <p>Добавяме услугите, цените, работното време, графика и отговорите, които вече използва екипът ви.</p>
      </div>
      <div class="how-setup-list">
        <article>
          <span>1</span>
          <div><h3>Давате ни информацията за бизнеса</h3><p>Услуги, цени, работно време, адреси и въпросите, които клиентите задават най-често.</p></div>
        </article>
        <article>
          <span>2</span>
          <div><h3>Решавате какво може да поема</h3><p>Определяте какво да пита, какво да потвърждава и кога да прехвърли разговора.</p></div>
        </article>
        <article>
          <span>3</span>
          <div><h3>Тестваме реални ситуации</h3><p>Проверяваме чести въпроси, промени в последния момент и случаи, които трябва да стигнат до човек.</p></div>
        </article>
        <article>
          <span>4</span>
          <div><h3>Одобрявате всичко преди включването</h3><p>Чувате как звучи, преглеждате отговорите и решавате кога да поеме първото обаждане.</p></div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">телефон, календар и работно време</p>
          <h2>Vdiga отговаря по вашия график и записва директно в календара.</h2>
        </div>
        <p>Вие определяте кога да отговаря, какво може да потвърждава и в кои случаи да ви потърси.</p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Свързваме</th>
              <th>Вие задавате</th>
              <th>Vdiga прави</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td data-label="Свързваме">Телефонна линия</td>
              <td data-label="Вие задавате">В кои дни и часове да отговаря</td>
              <td data-label="Vdiga прави">Поема обажданията в избраното от вас време</td>
            </tr>
            <tr>
              <td data-label="Свързваме">Календар</td>
              <td data-label="Вие задавате">Услуги, продължителност и налични часове</td>
              <td data-label="Vdiga прави">Предлага свободен час и записва клиента</td>
            </tr>
            <tr>
              <td data-label="Свързваме">Информация за бизнеса</td>
              <td data-label="Вие задавате">Услуги, адрес, цени и чести въпроси</td>
              <td data-label="Vdiga прави">Отговаря само с одобрената информация</td>
            </tr>
            <tr>
              <td data-label="Свързваме">Правила за прехвърляне</td>
              <td data-label="Вие задавате">В кои случаи да ви потърси веднага</td>
              <td data-label="Vdiga прави">Прехвърля разговора или записва съобщение</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="lead" style="margin-top: 26px;">
        Искате първо да чуете как звучи? <a href={href("/demo/")}>Пуснете демото на български</a>, след това вижте <a href={href("/tseni/")}>цените</a> и <a href={href("/za-nas/")}>екипа зад Vdiga</a>.
      </p>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">кога се включва човек</p>
          <h2>Vdiga поема рутинните обаждания. Спешните и сложните стигат до вас.</h2>
        </div>
        <p>Вие решавате кои ситуации изискват човек. В останалите случаи Vdiga приключва разговора и ви изпраща резултата.</p>
      </div>
      <div class="how-boundaries">
        <article class="is-answer">
          <p class="eyebrow">Vdiga поема самостоятелно</p>
          <ul class="split-list">
            <li>чести въпроси за услуги, адрес и работно време</li>
            <li>записване, промяна и потвърждаване на часове</li>
            <li>събиране на име, телефон и причина за обаждането</li>
            <li>изпращане на резултата след разговора</li>
          </ul>
        </article>
        <article class="is-human">
          <p class="eyebrow">Vdiga ви включва при</p>
          <ul class="split-list">
            <li>спешни или чувствителни ситуации</li>
            <li>въпроси, за които няма одобрен отговор</li>
            <li>клиент, който изрично иска разговор с екипа</li>
            <li>ситуациите, които сте избрали да поемате лично</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">най-честите въпроси</p>
        <h2>Какво да знаете, преди да включите Vdiga?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section how-form-section">
    <div class="container">
      <OnboardingForm />
    </div>
  </section>

  <CTA title="Чуйте как Vdiga разговаря с клиент." text="Пуснете демото и преценете дали гласът и разговорът са подходящи за вашия бизнес." buttonLabel="Пуснете демото" playDemo={true} />
</BaseLayout>
