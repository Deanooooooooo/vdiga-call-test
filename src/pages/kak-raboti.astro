---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductVisual from "../components/ProductVisual.astro";
import OnboardingForm from "../components/OnboardingForm.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { faqSchema, serviceSchema } from "../data/schema";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;

const faqs = [
  {
    question: "Трябва ли да сменя телефонния си номер?",
    answer:
      "Не е задължително. Уточняваме как приемате обажданията си сега и настройваме Vdiga според този процес. Вие решавате кои обаждания да поема и кога.",
  },
  {
    question: "Как Vdiga знае какво да каже?",
    answer:
      "Вие одобрявате информацията за услугите, цените, работното време и честите въпроси. Задавате и правилата за прехвърляне към човек. Vdiga използва само тази информация и не измисля отговори.",
  },
  {
    question: "Може ли да записва часове?",
    answer:
      "Да. Когато свържем календара ви, Vdiga проверява свободните часове, предлага удобен вариант и записва уговореното според вашите правила.",
  },
  {
    question: "Какво става, ако разговорът е сложен или спешен?",
    answer:
      "Вие определяте кои случаи трябва да стигнат до човек. Vdiga може да прехвърли разговора, да вземе съобщение или да го отбележи като спешен.",
  },
  {
    question: "Какво получавам след разговора?",
    answer:
      "Получавате кратко обобщение: кой се е обадил, какво е поискал и какво е уговорено. Ако е нужно да направите нещо, ще го видите веднага.",
  },
  {
    question: "Как се нарича AI рецепционист на английски?",
    answer:
      "Най-често се използва „AI receptionist“. Срещат се и „AI answering service“ и „voice AI assistant“. На български използваме „AI рецепционист“.",
  },
];
---

<BaseLayout
  title="Как работи AI рецепционистът на Vdiga?"
  description="Vdiga отговаря на обажданията, записва часове и ви изпраща кратко обобщение. Вижте как протича разговорът и как става настройката."
  path="/kak-raboti"
  image="/assets/vdiga-og-kak-raboti.png"
  imageAlt="Как работи AI рецепционистът Vdiga в четири стъпки"
  schemas={[faqSchema(faqs), serviceSchema("AI рецепционистът на Vdiga", "/kak-raboti", "Vdiga отговаря на входящи обаждания на български, записва часове и изпраща кратко обобщение след разговора.")]}
>
  <section class="hero how-hero">
    <div class="container">
      <p class="eyebrow">от позвъняването до готовия резултат</p>
      <h1>Как работи AI рецепционистът на Vdiga?</h1>
      <p class="answer-block">
        Vdiga е AI (изкуствен интелект) рецепционист за входящи обаждания. Поздравява клиента, разбира защо се обажда, записва час или взема съобщение и ви изпраща кратко обобщение. Вие определяте какво може да прави сам и кога да прехвърли разговора към човек.
      </p>
      <p class="lead">
        Докато вие сте с клиент, Vdiga вдига телефона. Разговорът завършва със записан час, прието съобщение или прехвърляне към човек.
      </p>
      <div class="button-row hero-actions">
        <button class="btn btn-primary" type="button" data-play-demo aria-pressed="false">Чуйте как звучи</button>
        <a class="btn btn-secondary" href="#nastroyka">Вижте настройката</a>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">един разговор в четири стъпки</p>
          <h2>Как протича разговорът с AI рецепциониста?</h2>
        </div>
        <p>За клиента това е обикновено телефонно обаждане. Vdiga се представя, изслушва го и следва правилата, които сте задали.</p>
      </div>
      <div class="how-flow">
        <article>
          <span>01</span>
          <h3>Вдига телефона</h3>
          <p>Поздравява клиента от името на бизнеса ви и казва, че е AI асистент.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Разбира от какво има нужда клиентът</h3>
          <p>Пита само за нужната информация — услуга, предпочитан ден, час или адрес.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Свършва конкретна работа</h3>
          <p>Записва час, приема запитването, взема съобщение или прехвърля разговора към човек.</p>
        </article>
        <article>
          <span>04</span>
          <h3>Изпраща ви обобщение</h3>
          <p>Виждате кой се е обадил, какво е поискал и какво е уговорено. Ако има задача за вас, тя е отбелязана.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section how-proof-section">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">след разговора</p>
          <h2>Получавате най-важното, без да преслушвате разговора.</h2>
        </div>
        <p>Vdiga ви изпраща кратко обобщение: кой се е обадил, защо и какво е уговорено.</p>
      </div>
      <ProductVisual />
    </div>
  </section>

  <section class="section band" id="nastroyka">
    <div class="container how-setup">
      <div class="how-setup-copy">
        <p class="eyebrow">вашият бизнес, вашите правила</p>
        <h2>Как подготвяме Vdiga за вашия бизнес?</h2>
        <p>Не използваме един и същ сценарий за всички. Настройваме Vdiga според услугите, графика и начина, по който работи екипът ви.</p>
      </div>
      <div class="how-setup-list">
        <article>
          <span>1</span>
          <div><h3>Събираме нужната информация</h3><p>Разказвате ни за услугите, работното време, адресите и най-честите обаждания.</p></div>
        </article>
        <article>
          <span>2</span>
          <div><h3>Уточняваме какво да прави</h3><p>Решавате какво да пита, какво може да потвърди и кога да включи човек.</p></div>
        </article>
        <article>
          <span>3</span>
          <div><h3>Проверяваме трудните случаи</h3><p>Тестваме ясни, неясни и сложни разговори, преди Vdiga да отговори на истински клиент.</p></div>
        </article>
        <article>
          <span>4</span>
          <div><h3>Включвате Vdiga, когато сте готови</h3><p>Първо чувате как звучи и одобрявате отговорите. След това Vdiga поема реални обаждания.</p></div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">номер, календар и правила</p>
          <h2>Как Vdiga се свързва с телефона и календара ви?</h2>
        </div>
        <p>Вие решавате кои обаждания да поема, какво да казва и кога да включи човек.</p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Свързваме</th>
              <th>Вие задавате</th>
              <th>Vdiga прави</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td data-label="Свързваме">Телефонна линия</td>
              <td data-label="Вие задавате">Кои обаждания и кога да поема</td>
              <td data-label="Vdiga прави">Отговаря според работното време и правилата ви</td>
            </tr>
            <tr>
              <td data-label="Свързваме">Календар</td>
              <td data-label="Вие задавате">Услуги, продължителност и свободни часове</td>
              <td data-label="Vdiga прави">Проверява свободните часове и записва клиента в избрания час</td>
            </tr>
            <tr>
              <td data-label="Свързваме">Информация за бизнеса</td>
              <td data-label="Вие задавате">Услуги, адрес, цени и чести въпроси</td>
              <td data-label="Vdiga прави">Отговаря само с одобрената информация</td>
            </tr>
            <tr>
              <td data-label="Свързваме">Правила за прехвърляне</td>
              <td data-label="Вие задавате">Кои случаи са сложни, спешни или важни</td>
              <td data-label="Vdiga прави">Включва човек или взема съобщение</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="lead" style="margin-top: 26px;">
        Първо <a href={href("/demo")}>чуйте демото на български</a>. После разгледайте <a href={href("/tseni")}>цените</a> и вижте <a href={href("/za-nas")}>кой стои зад Vdiga</a>.
      </p>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">ясни граници</p>
          <h2>Какво поема Vdiga и кога включва човек?</h2>
        </div>
        <p>Vdiga не гадае. Когато въпросът излиза извън зададените правила, разговорът стига до човек.</p>
      </div>
      <div class="how-boundaries">
        <article class="is-answer">
          <p class="eyebrow">Vdiga може да поеме</p>
          <ul class="split-list">
            <li>чести въпроси за услуги, адрес и работно време</li>
            <li>записване и уточняване на часове</li>
            <li>събиране на име, телефон и причина за обаждането</li>
            <li>обобщение след всеки разговор</li>
          </ul>
        </article>
        <article class="is-human">
          <p class="eyebrow">Vdiga включва човек при</p>
          <ul class="split-list">
            <li>спешни или чувствителни ситуации</li>
            <li>въпроси, за които няма одобрен отговор</li>
            <li>клиент, който изрично иска разговор с екипа</li>
            <li>всеки случай, който искате да поемете лично</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">преди да започнете</p>
        <h2>Какво още е добре да знаете?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section how-form-section">
    <div class="container">
      <OnboardingForm />
    </div>
  </section>

  <CTA title="Преди да решите, чуйте го." text="Пуснете демо разговора и преценете дали Vdiga звучи добре за вашите клиенти." buttonLabel="Чуйте разговора" playDemo={true} />
</BaseLayout>
