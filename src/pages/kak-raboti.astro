---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProductVisual from "../components/ProductVisual.astro";
import OnboardingForm from "../components/OnboardingForm.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { faqSchema, serviceSchema } from "../data/schema";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;

const faqs = [
  {
    question: "Трябва ли да сменя телефонния си номер?",
    answer:
      "Не е задължително. Настройката се съобразява с начина, по който приемате обажданията си сега. Преди включване уточняваме кои линии и в кои моменти трябва да поема Vdiga.",
  },
  {
    question: "Как Vdiga знае какво да отговаря?",
    answer:
      "Вие одобрявате услугите, работното време, ценовата информация, въпросите към клиента и правилата за пренасочване. Vdiga отговаря по тази информация, а не импровизира извън нея.",
  },
  {
    question: "Може ли да записва часове?",
    answer:
      "Да. Когато свържем календара ви, Vdiga проверява свободните часове, предлага удобен вариант и записва уговореното според вашите правила.",
  },
  {
    question: "Какво става, ако разговорът е сложен или спешен?",
    answer:
      "Предварително задаваме кога Vdiga трябва да пренасочи към човек, да вземе съобщение или да отбележи разговора като приоритетен. Вие решавате границите.",
  },
  {
    question: "Какво получавам след разговора?",
    answer:
      "Получавате най-важното: кой се е обадил, какво иска, какво е уговорено и дали е нужно действие от вашия екип.",
  },
  {
    question: "Какво означава „AI receptionist“?",
    answer:
      "„AI receptionist“ е английският термин за AI рецепционист. Това е телефонен асистент, който отговаря на входящи обаждания, следва одобрени правила, записва часове и пренасочва сложните случаи към човек.",
  },
];
---

<BaseLayout
  title="Как работи AI рецепционист на български | Vdiga"
  description="Как работи AI рецепционистът Vdiga: приема обаждания на български, записва часове в календар и изпраща ясно обобщение."
  path="/kak-raboti"
  image="/assets/vdiga-og-kak-raboti.png"
  imageAlt="Как работи AI рецепционистът Vdiga в четири стъпки"
  schemas={[faqSchema(faqs), serviceSchema("Как работи AI рецепционистът Vdiga", "/kak-raboti", "Vdiga приема входящи обаждания на български, записва часове в свързан календар и изпраща структурирано обобщение.")]}
>
  <section class="hero how-hero">
    <div class="container">
      <p class="eyebrow">от обаждане до свършена работа</p>
      <h1>Как работи AI рецепционистът на Vdiga?</h1>
      <p class="answer-block">
        Vdiga е AI (изкуствен интелект) рецепционист, който обработва входящото обаждане в четири стъпки: отговаря на естествен български, разбира причината, предприема одобреното действие и изпраща ясно обобщение. Vdiga може да записва часове в свързан календар и да пренасочва сложните случаи към човек.
      </p>
      <p class="lead">
        Vdiga не просто вдига. Довежда разговора до резултат. Вие определяте какво може да прави, какво да пита и кога разговорът трябва да стигне до човек.
      </p>
      <div class="button-row hero-actions">
        <button class="btn btn-primary" type="button" data-play-demo aria-pressed="false">Чуйте как звучи</button>
        <a class="btn btn-secondary" href="#nastroyka">Вижте настройката</a>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">един разговор, четири ясни стъпки</p>
          <h2>Как работи AI рецепционистът при входящо обаждане?</h2>
        </div>
        <p>За клиента това е нормален телефонен разговор. Зад него Vdiga следва процеса, който сте одобрили.</p>
      </div>
      <div class="how-flow">
        <article>
          <span>01</span>
          <h3>Отговаря веднага</h3>
          <p>Поздравява от името на бизнеса и дава на клиента ясен знак, че е попаднал на правилното място.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Разбира защо звъни</h3>
          <p>Задава точните уточняващи въпроси: услуга, удобен ден и час, адрес или друга нужна информация.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Предприема действие</h3>
          <p>Записва час, приема запитване, взема съобщение или пренасочва според зададените от вас правила.</p>
        </article>
        <article>
          <span>04</span>
          <h3>Оставя ясен резултат</h3>
          <p>Получавате кой се е обадил, какво иска, какво е уговорено и има ли нещо, което трябва да поемете.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section how-proof-section">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">след разговора няма догадки</p>
          <h2>Виждате резултата, без да слушате целия разговор.</h2>
        </div>
        <p>Vdiga превръща свободния телефонен разговор в структурирана информация, с която екипът ви може да действа.</p>
      </div>
      <ProductVisual />
    </div>
  </section>

  <section class="section band" id="nastroyka">
    <div class="container how-setup">
      <div class="how-setup-copy">
        <p class="eyebrow">вашият бизнес, вашите правила</p>
        <h2>Преди първото обаждане настройваме как Vdiga трябва да работи за вас.</h2>
        <p>Не получавате универсален бот. Получавате рецепционист, настроен според услугите, графика и начина, по който вашият екип работи.</p>
      </div>
      <div class="how-setup-list">
        <article>
          <span>1</span>
          <div><h3>Разбираме бизнеса ви</h3><p>Услуги, работно време, локации, чести въпроси и причините, поради които клиентите звънят.</p></div>
        </article>
        <article>
          <span>2</span>
          <div><h3>Задаваме правилата</h3><p>Какво да пита, какво може да потвърждава и кога да прехвърля разговора към човек.</p></div>
        </article>
        <article>
          <span>3</span>
          <div><h3>Тестваме реални сценарии</h3><p>Проверяваме нормални, неясни и сложни разговори, преди Vdiga да поеме клиенти.</p></div>
        </article>
        <article>
          <span>4</span>
          <div><h3>Включваме след одобрение</h3><p>Чувате как звучи и потвърждавате поведението. Едва тогава включваме реалните обаждания.</p></div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">номер, календар и правила</p>
          <h2>Как се настройва AI рецепционистът с вашия календар?</h2>
        </div>
        <p>Вие одобрявате информацията и границите. Vdiga използва само тях при входящите обаждания.</p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Какво свързваме</th>
              <th>Какво определяте вие</th>
              <th>Какво прави Vdiga</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td data-label="Какво свързваме">Телефонна линия</td>
              <td data-label="Какво определяте вие">Кои обаждания и кога да поема</td>
              <td data-label="Какво прави Vdiga">Отговаря според работното време и правилата ви</td>
            </tr>
            <tr>
              <td data-label="Какво свързваме">Календар</td>
              <td data-label="Какво определяте вие">Услуги, продължителност и свободни часове</td>
              <td data-label="Какво прави Vdiga">Проверява наличност и записва уговорения час</td>
            </tr>
            <tr>
              <td data-label="Какво свързваме">Информация за бизнеса</td>
              <td data-label="Какво определяте вие">Услуги, адрес, цени и чести въпроси</td>
              <td data-label="Какво прави Vdiga">Отговаря само с одобрената информация</td>
            </tr>
            <tr>
              <td data-label="Какво свързваме">Правила за пренасочване</td>
              <td data-label="Какво определяте вие">Кои случаи са сложни, спешни или приоритетни</td>
              <td data-label="Какво прави Vdiga">Пренасочва към човек или взема съобщение</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="lead" style="margin-top: 26px;">
        Чуйте <a href={href("/demo")}>AI рецепционист демо на български</a>, проверете <a href={href("/tseni")}>цената на AI рецепционист</a> или вижте <a href={href("/za-nas")}>кой стои зад Vdiga</a>.
      </p>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="how-section-head">
        <div>
          <p class="eyebrow">ясни граници</p>
          <h2>Автоматизира рутинното. Оставя важните решения на вас.</h2>
        </div>
        <p>Целта не е AI да се преструва, че знае всичко. Целта е клиентът да получи отговор, а сложният случай да стигне до правилния човек.</p>
      </div>
      <div class="how-boundaries">
        <article class="is-answer">
          <p class="eyebrow">Vdiga поема</p>
          <ul class="split-list">
            <li>чести въпроси за услуги, адрес и работно време</li>
            <li>записване и уточняване на часове</li>
            <li>събиране на име, телефон и причина за обаждането</li>
            <li>обобщение след всеки разговор</li>
          </ul>
        </article>
        <article class="is-human">
          <p class="eyebrow">към човек</p>
          <ul class="split-list">
            <li>спешни или чувствителни ситуации</li>
            <li>случаи извън одобрената информация</li>
            <li>клиент, който изрично иска разговор с екипа</li>
            <li>всичко, което вие определите като приоритетно</li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">преди да започнете</p>
        <h2>Най-важните въпроси за начина на работа.</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section how-form-section">
    <div class="container">
      <OnboardingForm />
    </div>
  </section>

  <CTA title="Искате първо да го чуете? Така трябва." text="Пуснете примерния разговор и преценете сами дали Vdiga звучи като правилния първи контакт за вашите клиенти." buttonLabel="Чуйте примерен разговор" playDemo={true} />
</BaseLayout>
