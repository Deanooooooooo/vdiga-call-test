---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import ArticleMeta from "../components/ArticleMeta.astro";
import { articleSchema, faqSchema } from "../data/schema";
import { contentPageByPath } from "../data/content-pages";

const faqs = [
  {
    question: "Колко време отнема настройката?",
    answer:
      "Целта е първият тестов AI рецепционист да е готов до 10 минути след подаване на сайт, Google профил или Facebook страница.",
  },
  {
    question: "С какъв календар работи v1?",
    answer:
      "Първата версия работи най-чисто с Cal.com API. Така Vdiga проверява свободни часове без тежка настройка за всеки клиент.",
  },
  {
    question: "Какво става при спешен случай?",
    answer:
      "Vdiga следва вашите правила. При спешен или неясен случай асистентът пренасочва, взема съобщение или маркира разговора за човек.",
  },
  {
    question: "Как се казва това на английски?",
    answer:
      "Най-близките английски термини са AI receptionist, voice AI assistant и AI answering service.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
const page = contentPageByPath["/kak-raboti"];
---

<BaseLayout
  title="Как работи AI рецепционист — Vdiga"
  description="Как работи AI рецепционист: Vdiga вдига, пита, проверява календар, записва час и праща обобщение след разговора."
  path="/kak-raboti"
  schemas={[faqSchema(faqs), articleSchema("Как работи AI рецепционист — Vdiga", "/kak-raboti", "Стъпка по стъпка как AI рецепционист отговаря и записва часове.", page)]}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">как работи AI рецепционист</p>
      <h1>Как работи AI рецепционистът при входящо обаждане?</h1>
      <p class="answer-block">
        Vdiga приема входящото обаждане, пита за нужната услуга, проверява календара и записва час. AI (изкуствен интелект) рецепционистът покрива моментите, в които никой не може да вдигне.
      </p>
      <p class="lead">
        Не учите нова система. Подавате публичната информация, слушате тестовите разговори и включвате реалния номер след одобрение.
      </p>
      <ArticleMeta datePublished={page.datePublished} dateModified={page.dateModified} />
      <div class="button-row hero-actions">
        <a class="btn btn-primary" href={href("/demo")}>Чуйте разговор</a>
        <a class="btn btn-secondary" href={href("/tseni")}>Вижте планове</a>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <p class="eyebrow">поток на обаждане</p>
      <h2>Какво се случва при едно входящо обаждане?</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Стъпка</th>
              <th>Какво прави Vdiga</th>
              <th>Какво виждате вие</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>1. Отговор</td>
              <td>Вдига телефона и се представя като AI асистент.</td>
              <td>Няма пропуснато първо обаждане.</td>
            </tr>
            <tr>
              <td>2. Уточнение</td>
              <td>Пита за услуга, спешност, име и удобен час.</td>
              <td>Получавате ясна информация, не бележки на ръка.</td>
            </tr>
            <tr>
              <td>3. Календар</td>
              <td>Проверява свободни часове според правилата.</td>
              <td>Календарът остава източникът на истината.</td>
            </tr>
            <tr>
              <td>4. Обобщение</td>
              <td>Праща кратко обобщение след разговора.</td>
              <td>Виждате какво е станало, без да слушате целия разговор.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">настройка</p>
        <h2>Как Vdiga разбира вашия бизнес?</h2>
        <p>
          Първата настройка не започва от празен чат. Vdiga взема услуги, работно време, адрес и правила от сайта, Google профила или Facebook страницата ви.
        </p>
      </div>
      <div>
        <ol class="split-list">
          <li>Подавате сайт, Google профил или Facebook страница.</li>
          <li>Системата създава профил, FAQ база и правила за пренасочване.</li>
          <li>Пускат се 3 тестови разговора преди реален трафик.</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <p class="eyebrow">първа версия</p>
      <h2>Кои части влизат в първата версия?</h2>
      <div class="grid-3">
        <article class="feature">
          <h3>Гласов слой</h3>
          <p>Разговорът минава през готова гласова услуга. Vdiga не строи телефонна инфраструктура от нулата.</p>
        </article>
        <article class="feature">
          <h3>Twilio</h3>
          <p>Телефонният слой минава през Twilio. Българският номер се показва след успешни тестови разговори.</p>
        </article>
        <article class="feature">
          <h3>Cal.com</h3>
          <p>Свободните часове се проверяват през Cal.com API. Календарът остава източникът на истината.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">чести въпроси</p>
        <h2>Какво пита собственикът преди настройка?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Първо работещ разговор. После реални клиенти." text="Vdiga трябва да мине теста на гласа, календара и пренасочването преди реални обаждания." />
</BaseLayout>
