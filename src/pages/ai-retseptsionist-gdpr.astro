---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQ from "../components/FAQ.astro";
import OnboardingForm from "../components/OnboardingForm.astro";
import { articleSchema, faqSchema } from "../data/schema";
import { withBase as href } from "../data/site";

const path = "/ai-retseptsionist-gdpr/";
const title = "AI рецепционист и GDPR: лични данни и сигурност | Vdiga";
const description = "AI рецепционист и GDPR: роли, правно основание, уведомяване, записи, срокове, здравни данни, договор по чл. 28 и оценка на риска.";
const headline = "AI рецепционист и GDPR: сигурност на разговорите и личните данни";
const faqs = [
  { question: "Съвместим ли е AI рецепционистът с GDPR?", answer: "Може да бъде внедрен в съответствие с GDPR, но това не става автоматично чрез една настройка или значка. Необходими са определени роли, цел и правно основание, подходящо уведомяване, минимизиране на данните, срокове, договорни правила и мерки за сигурност според конкретния процес." },
  { question: "Трябва ли всеки разговор да се записва?", answer: "Не. Аудиозаписът е отделна операция по обработване и трябва да има конкретна необходимост. Много задачи могат да работят с извлечени данни и кратко обобщение без дългосрочно съхранение на аудио. Ако се записва, клиентът трябва да определи цел, правно основание, уведомяване, достъп и срок." },
  { question: "Нужно ли е съгласие за записване на разговор?", answer: "Не може да се даде универсален отговор за всеки сценарий. Съгласието е само едно от възможните основания по GDPR и трябва да бъде свободно, конкретно, информирано и доказуемо. В други случаи може да се разглежда друго основание, но администраторът трябва да направи и документира оценката преди старта." },
  { question: "Кой е администратор и кой е обработващ?", answer: "Когато бизнесът решава защо и какви данни да се събират от неговите обаждания, той обичайно е администратор. Когато Vdiga обработва тези данни от негово име и по договорени инструкции, Vdiga обичайно е обработващ. Точните роли се потвърждават за конкретното внедряване." },
  { question: "Може ли AI рецепционист да обработва здравни данни?", answer: "Данните за здравето са специална категория по член 9 GDPR. Само основание по член 6 не е достатъчно: администраторът трябва да установи и приложимо условие по член 9, да ограничи събирането до необходимото и да приложи по-високи организационни и технически мерки." },
  { question: "Колко време се пазят данните от разговорите?", answer: "Няма един срок за всички клиенти и цели. Срокът трябва да следва целта, необходимостта, договорните и законовите задължения. Преди старта се определят отделни правила за аудио, транскрипт, обобщение, записан час и технически логове." },
  { question: "Нужна ли е оценка на въздействието върху защитата на данните?", answer: "Оценка по член 35 GDPR може да е необходима, когато планираното обработване вероятно създава висок риск — например при нови технологии, систематично обработване или чувствителни данни в голям мащаб. Решението принадлежи на администратора и трябва да бъде документирано преди продукционния старт." },
];
---

<BaseLayout title={title} description={description} path={path} pageClass="gdpr-page" ogType="article" schemas={[articleSchema({ headline, description, path, datePublished: "2026-07-16", dateModified: "2026-07-16" }), faqSchema(faqs)]}>
  <section class="hero gdpr-hero"><div class="container gdpr-hero-grid"><div><p class="eyebrow">GDPR при телефонен AI</p><h1>{headline}</h1><p class="answer-block">AI рецепционист може да бъде внедрен в съответствие с GDPR, когато ролите, целите, правното основание, уведомяването, сроковете и достъпът са определени преди първия реален разговор. Няма универсална настройка, която сама да прави един процес законосъобразен.</p><div class="button-row hero-actions"><a class="btn btn-primary" href="#proverka">Проверете вашия процес</a><a class="btn btn-secondary" href="#otgovori">Вижте кратките отговори</a></div></div><aside class="gdpr-brief" aria-label="GDPR преглед преди старт"><p class="brief-kicker">Преди продукционен старт</p><div><span>01</span><strong>Кой определя целта?</strong><small>Ролите се описват за конкретния процес.</small></div><div><span>02</span><strong>Кои данни са нужни?</strong><small>Събира се само необходимото за задачата.</small></div><div><span>03</span><strong>Колко време се пазят?</strong><small>Срокът следва целта, не удобството.</small></div><div><span>04</span><strong>Кой има достъп?</strong><small>Достъпът се ограничава и управлява.</small></div></aside></div></section>

  <section class="section band"><div class="container trust-head"><div><p class="eyebrow">първо ролите</p><h2>Бизнесът определя защо. Vdiga изпълнява договореното.</h2></div><p>При типично внедряване клиентът решава за каква цел се приемат разговорите, кои данни са нужни и какво да се случи с тях. Vdiga обработва от негово име по описани инструкции. Конкретният договор може да изисква различна квалификация за отделна операция.</p></div><div class="container role-grid"><article class="role-card controller"><p class="role-label">Администратор</p><h3>Вашият бизнес</h3><ul><li>определя целта и правното основание</li><li>одобрява репликите и полетата</li><li>определя сроковете и получателите</li><li>отговаря на исканията на хората</li></ul></article><div class="role-link" aria-hidden="true"><span>договор и инструкции</span><i>→</i></div><article class="role-card processor"><p class="role-label">Обработващ</p><h3>Vdiga</h3><ul><li>обработва по документирани инструкции</li><li>ограничава достъпа до необходимото</li><li>подпомага договорените GDPR процеси</li><li>прилага мерки според оценения риск</li></ul></article></div><div class="container legal-note"><strong>Важно:</strong><span>Това е общият модел, не автоматично заключение за всеки договор. Ролите се потвърждават според реалния поток на данните.</span></div></section>

  <section class="section"><div class="container trust-head"><div><p class="eyebrow">по-малко данни, по-малък риск</p><h2>Не всеки разговор трябва да става постоянен запис.</h2></div><p>За записване на час често са достатъчни име, телефон, избрана услуга и уговорен час. Аудиото, пълният транскрипт и свободният разказ трябва да се оценяват отделно, а не да се пазят „за всеки случай“.</p></div><div class="data-ladder"><article><span>Нужно за задачата</span><h3>Записан резултат</h3><p>Например име, контакт, услуга, дата и час.</p><b>Обичайно ядро</b></article><article><span>Само при необходимост</span><h3>Кратко обобщение</h3><p>Причина за обаждането и договорена следваща стъпка.</p><b>Ограничен контекст</b></article><article><span>Отделна оценка</span><h3>Транскрипт или аудио</h3><p>Конкретна цел, основание, уведомяване, достъп и срок.</p><b>По-висок риск</b></article></div></section>

  <section class="section gdpr-dark"><div class="container grid-2"><div><p class="eyebrow">записване на разговори</p><h2>„Записваме всичко“ не е правно основание.</h2><p>Записът е обработване на лични данни. Преди да бъде включен, администраторът трябва да определи защо е необходим, на какво основание се извършва, как човекът ще бъде информиран, кой ще слуша и кога записът ще бъде изтрит.</p><p>Съгласието не е магическа дума и не е единственото възможно основание. Ако се използва, то трябва да покрива изискванията на GDPR. Ако се използва друго основание, оценката трябва да бъде конкретна и документирана.</p></div><div class="recording-check"><p class="recording-title">Решението за запис минава през 5 въпроса</p><ol><li><span>1</span>Има ли конкретна и необходима цел?</li><li><span>2</span>Какво е приложимото правно основание?</li><li><span>3</span>Как и кога информираме обаждащия се?</li><li><span>4</span>Кой има достъп и за какво?</li><li><span>5</span>Какъв е срокът и автоматичното изтриване?</li></ol></div></div></section>

  <section class="section band"><div class="container trust-head"><div><p class="eyebrow">медицина и дентална грижа</p><h2>Здравните данни изискват втори правен слой.</h2></div><p>Информацията за здравето е специална категория лични данни. Основание по член 6 GDPR не е достатъчно само по себе си; необходимо е и приложимо условие по член 9, плюс по-строги ограничения и мерки.</p></div><div class="health-grid"><article><span>01</span><h3>Административното остава административно</h3><p>Име, контакт, лекар, специалност, обект и час — без AI диагноза, лечение или свободно медицинско заключение.</p></article><article><span>02</span><h3>Чувствителният случай стига до човек</h3><p>Симптоми, резултати, рецепти, усложнения и медицинска преценка следват предварително одобрения ред за предаване.</p></article><article><span>03</span><h3>Оценката на риска е преди старта</h3><p>При вероятен висок риск администраторът преценява и документира необходимостта от оценка по член 35 GDPR.</p></article></div><div class="container sector-links"><a href={href("/ai-retseptsionist-dentalna-klinika/")}>GDPR контекст за дентална клиника <span>↗</span></a><a href={href("/ai-retseptsionist-meditsinski-tsentar/")}>GDPR контекст за медицински център <span>↗</span></a></div></section>

  <section class="section" id="proverka"><div class="container trust-head"><div><p class="eyebrow">контролен списък</p><h2>Какво трябва да е решено преди първия реален разговор?</h2></div><p>Не започваме от „какво може AI“. Започваме от конкретната бизнес задача и най-малкия обем данни, с който тя може да бъде изпълнена.</p></div><div class="launch-grid"><article><b>01</b><h3>Цел и основание</h3><p>Отделно за приемане на заявка, записване, аудио, анализ и последващ контакт.</p></article><article><b>02</b><h3>Уведомяване</h3><p>Кратка информация в началото и достъпен пълен текст според конкретния процес.</p></article><article><b>03</b><h3>Договор по член 28</h3><p>Предмет, срок, инструкции, поверителност, сигурност, подизпълнители и съдействие.</p></article><article><b>04</b><h3>Срокове и изтриване</h3><p>Отделно за аудио, транскрипт, обобщение, календарен запис и технически лог.</p></article><article><b>05</b><h3>Достъп и инциденти</h3><p>Кой вижда данните, как се отнема достъп и как се действа при нарушение.</p></article><article><b>06</b><h3>Права и оценка на риска</h3><p>Процес за искания на хората и DPIA, когато планираното обработване вероятно е високорисково.</p></article></div></section>

  <section class="section sources-band"><div class="container grid-2"><div><p class="eyebrow">официални източници</p><h2>Правните твърдения трябва да могат да се проверят.</h2><p>Тази страница е практичен преглед, а не индивидуален правен съвет. Конкретното основание и документация се определят според клиента, сектора и реалния поток на данните.</p></div><div class="source-list"><a href="https://eur-lex.europa.eu/eli/reg/2016/679/oj" target="_blank" rel="noopener noreferrer"><strong>Регламент (ЕС) 2016/679</strong><span>Членове 5, 6, 9, 13, 28, 32 и 35 ↗</span></a><a href="https://cpdp.bg/" target="_blank" rel="noopener noreferrer"><strong>Комисия за защита на личните данни</strong><span>Българският надзорен орган ↗</span></a><a href={href("/politika-za-poveritelnost/")}><strong>Политика за поверителност на Vdiga</strong><span>Данните от сайта и запитванията ↗</span></a></div></div></section>

  <section class="section" id="otgovori"><div class="container grid-2"><div><p class="eyebrow">чести въпроси</p><h2>Кратки отговори без фалшиви гаранции.</h2><p class="faq-lead">„GDPR compliant“ не е постоянно свойство на софтуера. Законосъобразността зависи от реалната цел, данните, ролите, договорите, настройките и начина на работа.</p></div><FAQ items={faqs} /></div></section>
  <section class="section band"><div class="container"><OnboardingForm title="Проверете процеса преди първия реален разговор." lead="Опишете бизнеса, вида обаждания и системите. Ще очертаем нужните данни, границите, достъпа и въпросите, които трябва да бъдат решени договорно или с правен консултант." businessPlaceholder="Например дентална клиника, медицински център или салон" callProblemPlaceholder="Например: записване на часове, аудиозапис, здравни данни или няколко обекта" /></div></section>
</BaseLayout>

<style>
  .gdpr-hero{background:linear-gradient(135deg,#f3f7f0 0%,#fafaf7 58%,#eef3eb 100%)}.gdpr-hero-grid{display:grid;grid-template-columns:minmax(0,1.12fr) minmax(0,.88fr);gap:72px;align-items:center}.gdpr-hero-grid>*{min-width:0}.gdpr-hero h1{max-width:18ch;color:var(--ink)}.gdpr-hero .answer-block{max-width:100%;color:var(--ink-soft);overflow-wrap:anywhere}.gdpr-hero .btn-secondary{border-color:var(--ink);color:var(--ink)}.gdpr-brief{padding:28px;border:1px solid rgba(8,29,17,.12);border-radius:22px;background:rgba(255,255,255,.82);box-shadow:0 34px 80px -54px rgba(8,29,17,.55)}.brief-kicker{margin:0 0 16px;color:var(--answer-deep);font-size:.75rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase}.gdpr-brief div{display:grid;grid-template-columns:42px 1fr;gap:2px 14px;padding:17px 0;border-top:1px solid var(--line)}.gdpr-brief div:first-of-type{border-top:0}.gdpr-brief span{grid-row:1/3;display:grid;width:38px;height:38px;place-items:center;border-radius:50%;background:var(--ink);color:var(--answer);font-family:var(--mono);font-size:.72rem;font-weight:900}.gdpr-brief strong{color:var(--ink)}.gdpr-brief small{color:var(--ink-soft);line-height:1.4}
  .trust-head{display:grid;grid-template-columns:1.08fr .92fr;gap:64px;align-items:end;margin-bottom:44px}.trust-head h2{margin-bottom:0}.trust-head>p{color:var(--ink-soft);font-size:1.13rem;font-weight:600;line-height:1.6}.role-grid{display:grid;grid-template-columns:1fr 140px 1fr;align-items:center}.role-card{min-height:360px;padding:34px;border-radius:20px}.role-card.controller{background:#e7f2e5}.role-card.processor{background:var(--ink);color:var(--paper)}.role-card.processor h3{color:var(--paper)}.role-label{color:var(--answer-deep);font-size:.76rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase}.processor .role-label{color:var(--answer)}.role-card ul{display:grid;gap:13px;margin-top:26px;padding-left:20px}.role-card li{line-height:1.45}.role-link{display:grid;gap:9px;justify-items:center;color:var(--ink-soft);font-size:.72rem;font-weight:800;text-align:center;text-transform:uppercase}.role-link i{color:var(--answer-deep);font-size:2rem;font-style:normal}.legal-note{display:flex;gap:10px;margin-top:18px;padding:16px 20px;border-left:4px solid var(--answer-deep);background:var(--paper);color:var(--ink-soft)}.legal-note strong{color:var(--ink)}
  .data-ladder,.health-grid,.launch-grid{display:grid;max-width:1180px;margin:0 auto;grid-template-columns:repeat(3,1fr);gap:14px;padding:0 24px}.data-ladder article{display:flex;min-height:310px;flex-direction:column;padding:30px;border:1px solid var(--line);border-radius:18px;background:var(--paper)}.data-ladder article:nth-child(2){background:#edf4ed}.data-ladder article:nth-child(3){background:#f2ece7}.data-ladder span,.health-grid span{color:var(--answer-deep);font-size:.75rem;font-weight:900;text-transform:uppercase}.data-ladder p,.health-grid p,.launch-grid p,.faq-lead{color:var(--ink-soft)}.data-ladder b{margin-top:auto;padding-top:20px;border-top:1px solid rgba(8,29,17,.12)}
  .gdpr-dark{background:var(--ink);color:var(--paper)}.gdpr-dark h2{color:var(--paper)}.gdpr-dark p{color:rgba(250,250,247,.76)}.recording-check{padding:32px;border-radius:20px;background:rgba(255,255,255,.08)}.recording-title{color:var(--paper)!important;font-weight:850}.recording-check ol{display:grid;gap:10px;margin:22px 0 0;padding:0;list-style:none}.recording-check li{display:grid;grid-template-columns:36px 1fr;gap:12px;align-items:center;padding:12px;border:1px solid rgba(255,255,255,.13);border-radius:12px;font-weight:700}.recording-check span{display:grid;width:34px;height:34px;place-items:center;border-radius:50%;background:var(--answer);color:#07120b}
  .health-grid article{min-height:290px;padding:30px;border-radius:18px;background:var(--paper)}.sector-links{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}.sector-links a{display:flex;justify-content:space-between;padding:18px 20px;border-radius:12px;background:var(--ink);color:var(--paper);font-weight:800;text-decoration:none}.sector-links span{color:var(--answer)}.launch-grid article{min-height:250px;padding:28px;border:1px solid var(--line);border-radius:18px}.launch-grid b{color:var(--answer-deep);font-family:var(--mono)}.sources-band{background:#e8eee5}.source-list{display:grid;gap:10px}.source-list a{display:grid;gap:4px;padding:18px 20px;border:1px solid rgba(8,29,17,.12);border-radius:13px;background:rgba(255,255,255,.72);color:var(--ink);text-decoration:none}.source-list span{color:var(--ink-soft);font-size:.9rem}
  @media(max-width:800px){.gdpr-hero-grid,.trust-head,.role-grid,.data-ladder,.health-grid,.sector-links,.launch-grid{grid-template-columns:minmax(0,1fr)}.gdpr-hero-grid{gap:36px}.gdpr-hero h1{max-width:100%;font-size:clamp(2.2rem,9.7vw,2.55rem);line-height:1.06;overflow-wrap:anywhere}.gdpr-hero .button-row{display:grid;grid-template-columns:1fr}.gdpr-hero .btn{width:100%;white-space:normal}.trust-head{gap:18px}.role-link{grid-template-columns:1fr auto 1fr}.role-link i{transform:rotate(90deg)}.role-card,.data-ladder article,.health-grid article,.launch-grid article{min-height:0}.gdpr-brief,.role-card,.recording-check{padding:24px}.data-ladder,.health-grid,.launch-grid{padding:0 18px}.legal-note{align-items:flex-start}}
</style>
