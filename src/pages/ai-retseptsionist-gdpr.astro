---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQ from "../components/FAQ.astro";
import OnboardingForm from "../components/OnboardingForm.astro";
import { articleSchema, faqSchema } from "../data/schema";
import { withBase as href } from "../data/site";

const path = "/ai-retseptsionist-gdpr/";
const title = "AI рецепционист и GDPR: лични данни и сигурност | Vdiga";
const description = "AI рецепционист и GDPR: роли, правно основание, уведомяване, записи, срокове, здравни данни, договор по чл. 28 и оценка на риска.";
const headline = "AI рецепционист и GDPR: сигурност на разговорите и личните данни";
const faqs = [
  { question: "Съвместим ли е AI рецепционистът с GDPR?", answer: "Може да бъде внедрен в съответствие с GDPR, но това не става автоматично чрез една настройка или значка. Необходими са определени роли, цел и правно основание, подходящо уведомяване, минимизиране на данните, срокове, договорни правила и мерки за сигурност според конкретния процес." },
  { question: "Трябва ли всеки разговор да се записва?", answer: "Не. Аудиозаписът е отделна операция по обработване и трябва да има конкретна необходимост. Много задачи могат да работят с извлечени данни и кратко обобщение без дългосрочно съхранение на аудио. Ако се записва, клиентът трябва да определи цел, правно основание, уведомяване, достъп и срок." },
  { question: "Нужно ли е съгласие за записване на разговор?", answer: "Не може да се даде универсален отговор за всеки сценарий. Съгласието е само едно от възможните основания по GDPR и трябва да бъде свободно, конкретно, информирано и доказуемо. В други случаи може да се разглежда друго основание, но администраторът трябва да направи и документира оценката преди старта." },
  { question: "Кой е администратор и кой е обработващ?", answer: "Обичайно бизнесът, който решава защо се събират данните от обажданията, е администратор. Доставчикът, който ги обработва само от негово име, може да е обработващ. Ролята на Vdiga и задълженията на всяка страна трябва да бъдат потвърдени в конкретната оферта и договор — тази страница не ги определя предварително." },
  { question: "Може ли AI рецепционист да обработва здравни данни?", answer: "Данните за здравето са специална категория по член 9 GDPR. Само основание по член 6 не е достатъчно: администраторът трябва да установи и приложимо условие по член 9, да ограничи събирането до необходимото и да приложи по-високи организационни и технически мерки." },
  { question: "Колко време се пазят данните от разговорите?", answer: "Няма един срок за всички клиенти и цели. Бизнесът трябва да определи колко време е необходимо да пази всеки вид данни. Преди покупка трябва да провери дали предлаганата конфигурация на Vdiga може да изпълни тези срокове; страницата не обещава автоматично изтриване или конкретен период." },
  { question: "Нужна ли е оценка на въздействието върху защитата на данните?", answer: "Оценка по член 35 GDPR може да е необходима, когато планираното обработване вероятно създава висок риск — например при чувствителни данни в голям мащаб. Решението е на администратора и при нужда следва да се вземе с квалифициран правен или DPO съвет преди реалното използване." },
];
---

<BaseLayout title={title} description={description} path={path} pageClass="gdpr-page" ogType="article" schemas={[articleSchema({ headline, description, path, datePublished: "2026-07-16", dateModified: "2026-07-16" }), faqSchema(faqs)]}>
  <section class="hero gdpr-hero"><div class="container gdpr-hero-content"><p class="eyebrow">GDPR при телефонен AI</p><h1>{headline}</h1><p class="answer-block">AI рецепционистът не е „GDPR съвместим“ сам по себе си. Законосъобразността зависи от конкретната употреба: какви данни се събират, защо, къде се изпращат и колко време се пазят. Тези условия трябва да бъдат проверени преди договор и преди първото реално обаждане.</p><div class="button-row hero-actions"><a class="btn btn-primary" href="#proverka">Какво да проверите</a><a class="btn btn-secondary" href="#otgovori">Кратки отговори</a></div></div></section>

  <section class="section band"><div class="container trust-head"><div><p class="eyebrow">първо ролите</p><h2>Кой решава защо се събират данните?</h2></div><p>Това е основният въпрос при определяне на ролите по GDPR. Бизнесът обичайно е администратор, когато определя целта на обажданията и нужната информация. Ролята на всеки доставчик зависи от реалната услуга и договора.</p></div><div class="container role-grid"><article class="role-card controller"><p class="role-label">Обичайно администратор</p><h3>Бизнесът, който приема обажданията</h3><ul><li>определя защо са нужни данните</li><li>избира каква информация да се поиска</li><li>определя правното основание и срока</li><li>отговаря на исканията на хората</li></ul></article><div class="role-link" aria-hidden="true"><span>проверка в договора</span><i>→</i></div><article class="role-card processor"><p class="role-label">Възможна роля</p><h3>Доставчикът на услугата</h3><ul><li>ролята му не се приема по подразбиране</li><li>договорът трябва да опише услугата и данните</li><li>мерките и съдействието се проверяват писмено</li><li>подизпълнителите и трансферите се уточняват</li></ul></article></div><div class="container legal-note"><strong>За Vdiga:</strong><span>Конкретната роля, наличните мерки, сроковете и задълженията се потвърждават в индивидуалната оферта и договор. Тази страница не обещава функции или договорни условия.</span></div></section>

  <section class="section"><div class="container trust-head"><div><p class="eyebrow">по-малко данни, по-малък риск</p><h2>Не е нужно всеки разговор да се пази.</h2></div><p>За записване на час често са достатъчни име, телефон, избрана услуга и уговорен час. Аудиото, пълният транскрипт и свободният разказ трябва да се оценяват отделно, а не да се пазят „за всеки случай“.</p></div><div class="data-ladder"><article><span>Нужно за задачата</span><h3>Записан резултат</h3><p>Например име, контакт, услуга, дата и час.</p><b>Обичайно ядро</b></article><article><span>Само при необходимост</span><h3>Кратко обобщение</h3><p>Причина за обаждането и какво е уговорено.</p><b>Ограничен контекст</b></article><article><span>Отделна оценка</span><h3>Транскрипт или аудио</h3><p>Конкретна цел, основание, уведомяване, достъп и срок.</p><b>По-висок риск</b></article></div></section>

  <section class="section gdpr-dark"><div class="container grid-2"><div><p class="eyebrow">записване на разговори</p><h2>Записът на разговора изисква отделно решение.</h2><p>Фактът, че една система може да записва, не означава, че записът е необходим или законосъобразен. Бизнесът трябва да определи защо му е нужен, на какво основание ще го прави и как ще информира обаждащия се.</p><p>Съгласието е само едно от възможните основания и не е подходящо във всеки случай. Изборът трябва да следва конкретната употреба, а не общ текст от интернет.</p></div><div class="recording-check"><p class="recording-title">Преди да включите запис</p><ol><li><span>1</span>Опишете защо аудиото е необходимо.</li><li><span>2</span>Определете приложимото правно основание.</li><li><span>3</span>Подгответе информация за обаждащия се.</li><li><span>4</span>Уточнете кой може да слуша записа.</li><li><span>5</span>Проверете как и кога може да бъде изтрит.</li></ol></div></div></section>

  <section class="section band"><div class="container trust-head"><div><p class="eyebrow">медицина и дентална грижа</p><h2>За здравните данни важат по-строги правила.</h2></div><p>Информацията за здравето е специална категория лични данни. Основание по член 6 GDPR не е достатъчно само по себе си; необходимо е и приложимо условие по член 9, плюс по-строги ограничения и мерки.</p></div><div class="health-grid"><article><span>01</span><h3>Ограничете задачата</h3><p>Проверете дали са достатъчни име, контакт, лекар, специалност, обект и час. Не възлагайте на AI диагноза, лечение или медицинско заключение.</p></article><article><span>02</span><h3>Опишете кога поема човек</h3><p>За симптоми, резултати, рецепти и усложнения трябва да има изрично правило. Дали Vdiga може да го изпълни се потвърждава за конкретната конфигурация.</p></article><article><span>03</span><h3>Проверете риска преди старт</h3><p>При вероятен висок риск администраторът преценява и документира необходимостта от оценка по член 35 GDPR.</p></article></div><div class="container sector-links"><a href={href("/ai-retseptsionist-dentalna-klinika/")}>AI рецепционист за дентална клиника <span>↗</span></a><a href={href("/ai-retseptsionist-meditsinski-tsentar/")}>AI рецепционист за медицински център <span>↗</span></a></div></section>

  <section class="section" id="proverka"><div class="container trust-head"><div><p class="eyebrow">преди договор</p><h2>Поискайте конкретни отговори, не общо обещание за GDPR.</h2></div><p>Този списък не описва автоматично налични функции на Vdiga. Той показва какво трябва да проверите в предложената конфигурация, договора и документите на всички участващи доставчици.</p></div><div class="launch-grid"><article><b>01</b><h3>Какви данни се събират?</h3><p>Полетата, аудиото, транскриптът, обобщението и техническите данни.</p></article><article><b>02</b><h3>Къде отиват?</h3><p>Телефонна платформа, AI доставчик, календар, CRM и други свързани системи.</p></article><article><b>03</b><h3>Какво пише в договора?</h3><p>Роли, инструкции, поверителност, мерки, подизпълнители и съдействие.</p></article><article><b>04</b><h3>Колко време се пазят?</h3><p>Отделен срок и реален начин за изтриване за всеки вид данни.</p></article><article><b>05</b><h3>Кой има достъп?</h3><p>Служители, администратори, доставчици и свързани системи.</p></article><article><b>06</b><h3>Нужен ли е правен преглед?</h3><p>Особено при записи, здравни данни, голям мащаб или трансфер извън ЕИП.</p></article></div></section>

  <section class="section sources-band"><div class="container grid-2"><div><p class="eyebrow">официални източници</p><h2>Правните твърдения трябва да могат да се проверят.</h2><p>Тази страница е практичен преглед, а не индивидуален правен съвет. Конкретното основание и документация се определят според клиента, сектора и реалния поток на данните.</p></div><div class="source-list"><a href="https://eur-lex.europa.eu/eli/reg/2016/679/oj" target="_blank" rel="noopener noreferrer"><strong>Регламент (ЕС) 2016/679</strong><span>Членове 5, 6, 9, 13, 28, 32 и 35 ↗</span></a><a href="https://cpdp.bg/" target="_blank" rel="noopener noreferrer"><strong>Комисия за защита на личните данни</strong><span>Българският надзорен орган ↗</span></a><a href={href("/politika-za-poveritelnost/")}><strong>Политика за поверителност на Vdiga</strong><span>Данните от сайта и запитванията ↗</span></a></div></div></section>

  <section class="section" id="otgovori"><div class="container grid-2"><div><p class="eyebrow">чести въпроси</p><h2>Най-важното за GDPR и телефонния AI.</h2><p class="faq-lead">Съответствието с GDPR зависи от това как AI рецепционистът се използва на практика: какви данни събира, за каква цел, при какви правила и с каква защита.</p></div><FAQ items={faqs} /></div></section>
  <section class="section band"><div class="container"><OnboardingForm title="Проверете дали Vdiga е подходяща за вашия случай." lead="Опишете задачата и системите, които използвате. Ще ви кажем каква конфигурация можем да предложим и каква техническа информация можем да предоставим. Правното основание и индивидуалната правна оценка остават отговорност на вашия бизнес и неговия консултант." businessPlaceholder="Например дентална клиника, медицински център или салон" callProblemPlaceholder="Например: записване на часове, аудиозапис, здравни данни или няколко обекта" /></div></section>
</BaseLayout>

<style>
  .gdpr-hero{background:linear-gradient(135deg,#f3f7f0 0%,#fafaf7 58%,#eef3eb 100%)}.gdpr-hero-content{max-width:1040px;margin-inline:auto}.gdpr-hero h1{max-width:18ch;color:var(--ink);font-size:clamp(2.65rem,4.4vw,4.5rem);line-height:1.02}.gdpr-hero .answer-block{max-width:850px;color:var(--ink-soft);overflow-wrap:anywhere}.gdpr-hero .btn-secondary{border-color:var(--ink);color:var(--ink)}
  .trust-head{display:grid;grid-template-columns:1.08fr .92fr;gap:64px;align-items:end;margin-bottom:44px}.trust-head h2{margin-bottom:0}.trust-head>p{color:var(--ink-soft);font-size:1.13rem;font-weight:600;line-height:1.6}.role-grid{display:grid;grid-template-columns:1fr 140px 1fr;align-items:center}.role-card{min-height:0;padding:10px 0 18px;border-top:3px solid var(--answer-deep);border-radius:0}.role-card.controller,.role-card.processor{background:transparent;color:var(--ink)}.role-card.processor h3{color:var(--ink)}.role-label{color:var(--answer-deep);font-size:.76rem;font-weight:900;letter-spacing:.1em;text-transform:uppercase}.processor .role-label{color:var(--answer-deep)}.role-card ul{display:grid;gap:13px;margin-top:26px;padding-left:20px}.role-card li{line-height:1.45}.role-link{display:grid;gap:9px;justify-items:center;color:var(--ink-soft);font-size:.72rem;font-weight:800;text-align:center;text-transform:uppercase}.role-link i{color:var(--answer-deep);font-size:2rem;font-style:normal}.legal-note{display:flex;gap:10px;margin-top:18px;padding:16px 20px;border-left:4px solid var(--answer-deep);background:var(--paper);color:var(--ink-soft)}.legal-note strong{color:var(--ink)}
  .data-ladder,.health-grid,.launch-grid{display:grid;max-width:1180px;margin:0 auto;grid-template-columns:repeat(3,1fr);gap:14px;padding:0 24px}.data-ladder article{display:flex;min-height:0;flex-direction:column;padding:24px 0;border-top:3px solid var(--ink);border-radius:0;background:transparent}.data-ladder article:nth-child(2),.data-ladder article:nth-child(3){background:transparent}.data-ladder span,.health-grid span{color:var(--answer-deep);font-size:.75rem;font-weight:900;text-transform:uppercase}.data-ladder p,.health-grid p,.launch-grid p,.faq-lead{color:var(--ink-soft)}.data-ladder b{margin-top:auto;padding-top:20px;border-top:1px solid rgba(8,29,17,.12)}
  .gdpr-dark{background:var(--ink);color:var(--paper)}.gdpr-dark h2{color:var(--paper)}.gdpr-dark p{color:rgba(250,250,247,.76)}.recording-check{padding:32px;border-radius:20px;background:rgba(255,255,255,.08)}.recording-title{color:var(--paper)!important;font-weight:850}.recording-check ol{display:grid;gap:10px;margin:22px 0 0;padding:0;list-style:none}.recording-check li{display:grid;grid-template-columns:36px 1fr;gap:12px;align-items:center;padding:12px;border:1px solid rgba(255,255,255,.13);border-radius:12px;font-weight:700}.recording-check span{display:grid;width:34px;height:34px;place-items:center;border-radius:50%;background:var(--answer);color:#07120b}
  .health-grid article{min-height:0;padding:24px 0;border-top:3px solid var(--answer-deep);border-radius:0;background:transparent}.sector-links{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px}.sector-links a{display:flex;justify-content:space-between;padding:16px 0;border-bottom:1px solid var(--line);border-radius:0;background:transparent;color:var(--ink);font-weight:800;text-decoration:none}.sector-links span{color:var(--answer-deep)}.launch-grid article{min-height:0;padding:22px 0;border:0;border-top:1px solid var(--line);border-radius:0}.launch-grid b{color:var(--answer-deep);font-family:var(--mono)}.sources-band{background:#e8eee5}.source-list{display:grid;gap:10px}.source-list a{display:grid;gap:4px;padding:18px 20px;border:1px solid rgba(8,29,17,.12);border-radius:13px;background:rgba(255,255,255,.72);color:var(--ink);text-decoration:none}.source-list span{color:var(--ink-soft);font-size:.9rem}
  @media(max-width:800px){.trust-head,.role-grid,.data-ladder,.health-grid,.sector-links,.launch-grid{grid-template-columns:minmax(0,1fr)}.gdpr-hero h1{max-width:100%;font-size:clamp(2.2rem,9.7vw,2.55rem);line-height:1.06;overflow-wrap:anywhere}.gdpr-hero .button-row{display:grid;grid-template-columns:1fr}.gdpr-hero .btn{width:100%;white-space:normal}.trust-head{gap:18px}.role-link{grid-template-columns:1fr auto 1fr}.role-link i{transform:rotate(90deg)}.role-card,.data-ladder article,.health-grid article,.launch-grid article{min-height:0}.recording-check{padding:24px}.role-card{padding:18px 0}.data-ladder,.health-grid,.launch-grid{padding:0 18px}.legal-note{align-items:flex-start}}
</style>
