---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQ from "../components/FAQ.astro";
import OnboardingForm from "../components/OnboardingForm.astro";
import { articleSchema, faqSchema } from "../data/schema";
import { withBase as href } from "../data/site";

const path = "/ai-retseptsionist-gdpr/";
const title = "AI рецепционист и GDPR: практическо ръководство | Vdiga";
const description = "Какви лични данни събира AI рецепционистът, кога е нужен запис, как се уведомява обаждащият се и какво да проверите преди договор.";
const headline = "AI рецепционист и GDPR: какво трябва да направи бизнесът";
const faqs = [
  { question: "Съвместим ли е AI рецепционистът с GDPR?", answer: "Може да бъде, но не автоматично. Бизнесът трябва да определи защо използва системата, какви данни са нужни, на какво правно основание ги обработва, как информира хората и колко време ги пази. Техническите възможности и договорите на доставчиците също трябва да отговарят на тези решения." },
  { question: "Трябва ли разговорът да се записва?", answer: "Не. За записване на час може да е достатъчно системата да предаде име, телефон, услуга и уговорен час. Ако искате да пазите аудио или пълен транскрипт, трябва отделно да обосновете защо са необходими." },
  { question: "Как трябва да започне разговорът?", answer: "Добрата прозрачна практика е още в началото да стане ясно кой е бизнесът, че разговорът се води от AI асистент и за какво ще бъдат използвани поисканите данни. Ако се пази аудиозапис, трябва да има и отделна информация за него." },
  { question: "Нужно ли е съгласие за запис?", answer: "Не може да се отговори еднакво за всеки случай. Съгласието е едно от възможните основания, но трябва да е свободно, конкретно, информирано и доказуемо. Бизнесът трябва да избере и документира приложимото основание за своята употреба." },
  { question: "Колко време могат да се пазят данните?", answer: "Няма универсален срок. Името и часът, аудиозаписът, транскриптът и техническите данни могат да имат различни срокове. Всеки срок трябва да е необходим за конкретна цел и да може реално да бъде изпълнен от използваните системи." },
  { question: "Какво е различното при медицински и дентални обаждания?", answer: "Симптомите, диагнозите, резултатите и друга информация за здравето са специална категория данни. Освен основание по член 6 GDPR е нужно и приложимо условие по член 9. Затова AI задачата е по-безопасно да бъде ограничена до административното, когато медицинската информация не е необходима." },
];
---

<BaseLayout title={title} description={description} path={path} pageClass="gdpr-page" ogType="article" schemas={[articleSchema({ headline, description, path, datePublished: "2026-07-16", dateModified: "2026-07-16" }), faqSchema(faqs)]}>
  <section class="hero gdpr-hero">
    <div class="container gdpr-hero-content">
      <p class="eyebrow">Практическо ръководство</p>
      <h1>{headline}</h1>
      <p class="answer-block">За да използвате AI рецепционист законосъобразно, първо опишете конкретната му задача. После събирайте само данните, без които тази задача не може да бъде изпълнена. Записът на разговор, пълният транскрипт и здравната информация изискват отделна преценка.</p>
      <div class="button-row"><a class="btn btn-primary" href="#primer">Вижте конкретен пример</a><a class="btn btn-secondary" href="#predi-dogovor">Преди договор</a></div>
    </div>
  </section>

  <section class="section" id="primer">
    <div class="container article-width">
      <p class="eyebrow">пример: записване на час</p>
      <h2>Какви данни действително са нужни?</h2>
      <p class="lead">Клиент се обажда в салон и иска час за маникюр в петък след 17:00. За тази задача обичайно са нужни име, телефон, услуга и избран час.</p>
      <div class="example-flow" aria-label="Пример за данни при записване на час">
        <div><strong>Клиентът казва</strong><p>„Искам маникюр в петък след работа.“</p></div>
        <div><strong>За записването са нужни</strong><p>Име, телефон, услуга, дата и час.</p></div>
        <div><strong>Не са нужни по подразбиране</strong><p>Лична карта, дата на раждане, пълен аудиозапис или безсрочен транскрипт.</p></div>
      </div>
      <p>Ако салонът иска и запис на целия разговор „за контрол“, това вече е друга цел. Тя трябва да има собствено правно основание, срок за съхранение и достъп само за хората, които действително го използват.</p>
    </div>
  </section>

  <section class="section band">
    <div class="container article-width">
      <p class="eyebrow">аудио и транскрипт</p>
      <h2>AI разговор не означава задължително аудиозапис.</h2>
      <p>Системата може да използва гласа, за да разбере заявката по време на разговора. Това не означава непременно, че аудиофайлът трябва да остане запазен след края му.</p>
      <h3>Кога записът изисква допълнително обяснение?</h3>
      <p>Когато бизнесът иска да слуша разговорите по-късно, да обучава служители, да решава спорове или да анализира качеството. За всяка такава цел трябва да е ясно защо записът е необходим, кой може да го слуша и кога се изтрива.</p>
      <div class="plain-note"><strong>Практично правило:</strong> ако задачата може да приключи с „Мария Иванова, маникюр, петък, 17:30“, не пазете по-богата информация без конкретна причина.</div>
    </div>
  </section>

  <section class="section disclosure-section">
    <div class="container article-width">
      <p class="eyebrow">начало на разговора</p>
      <h2>Какво трябва да чуе обаждащият се?</h2>
      <p>Човекът не бива да гадае къде се е обадил, дали говори с AI и защо му искат телефон. Началото може да бъде кратко:</p>
      <blockquote>„Здравейте, свързахте се с [име на бизнеса]. Аз съм AI асистент и мога да помогна със записване на час. Ще поискам име и телефон, за да потвърдим заявката.“</blockquote>
      <p>Ако разговорът се записва, съобщението трябва да го казва изрично и да насочва към пълната информация за обработването. Точният текст зависи от целта, правното основание и начина, по който бизнесът използва записа.</p>
    </div>
  </section>

  <section class="section band">
    <div class="container article-width">
      <p class="eyebrow">кой носи отговорност</p>
      <h2>Бизнесът не прехвърля GDPR отговорността на софтуера.</h2>
      <p>Клиниката, салонът или другият бизнес обичайно решава защо приема обажданията и каква информация иска от клиентите. Затова обичайно той е администраторът на тези данни.</p>
      <p>Доставчикът може да е обработващ, когато работи само от името на бизнеса и по негови инструкции. Това не се приема по подразбиране. Ролите, данните, подизпълнителите, мерките за сигурност и съдействието при искания трябва да са описани в договора.</p>
      <div class="plain-note"><strong>За Vdiga:</strong> конкретната роля и наличните технически и договорни условия се потвърждават в индивидуалната оферта. Тази информационна страница не ги заменя.</div>
    </div>
  </section>

  <section class="section health-section">
    <div class="container article-width">
      <p class="eyebrow">здравни данни</p>
      <h2>„Искам час при кардиолог“ и „Имам болка в гърдите“ не са еднакви заявки.</h2>
      <p>Първата заявка може да бъде обработена като административно записване. Втората разкрива информация за здравето и може да изисква медицинска преценка, която не трябва да се оставя на AI рецепционист.</p>
      <p>За медицински и дентални услуги ограничете въпросите до необходимото за записването. Опишете кога разговорът трябва да стигне до човек. Преди използване на здравни данни проверете приложимото условие по член 9 GDPR и дали е нужна оценка на въздействието по член 35.</p>
      <nav class="sector-links" aria-label="AI рецепционист за здравни бизнеси"><a href={href("/ai-retseptsionist-dentalna-klinika/")}>AI рецепционист за дентална клиника <span>↗</span></a><a href={href("/ai-retseptsionist-meditsinski-tsentar/")}>AI рецепционист за медицински център <span>↗</span></a></nav>
    </div>
  </section>

  <section class="section band" id="predi-dogovor">
    <div class="container article-width">
      <p class="eyebrow">преди договор</p>
      <h2>Шест въпроса, на които трябва да получите конкретен отговор.</h2>
      <ol class="contract-questions">
        <li><strong>Какви данни остават след разговора?</strong><span>Поискайте отделен отговор за аудио, транскрипт, обобщение, календар и технически записи.</span></li>
        <li><strong>Къде се обработват?</strong><span>Уточнете телефонната платформа, AI доставчика, календара, CRM системата и държавите, от които има достъп.</span></li>
        <li><strong>Кой може да ги види?</strong><span>Не само вашите служители, а и администраторите и подизпълнителите на доставчика.</span></li>
        <li><strong>Как се изтриват?</strong><span>Поискайте реален механизъм и срок за всеки вид данни, не общо обещание „според GDPR“.</span></li>
        <li><strong>Какво става при искане от клиент?</strong><span>Трябва да е възможно данните да бъдат намерени, предоставени, коригирани или изтрити, когато GDPR го изисква.</span></li>
        <li><strong>Какво точно пише в договора?</strong><span>Роли, инструкции, поверителност, сигурност, подизпълнители, инциденти и прекратяване.</span></li>
      </ol>
    </div>
  </section>

  <section class="section sources-section">
    <div class="container article-width">
      <p class="eyebrow">официални източници</p>
      <h2>Къде да проверите правните изисквания?</h2>
      <p>Тази страница дава обща информация, а не правен съвет за конкретен бизнес.</p>
      <ul class="source-list"><li><a href="https://eur-lex.europa.eu/eli/reg/2016/679/oj" target="_blank" rel="noopener noreferrer">Регламент (ЕС) 2016/679 — членове 5, 6, 9, 13, 28, 32 и 35 ↗</a></li><li><a href="https://cpdp.bg/" target="_blank" rel="noopener noreferrer">Комисия за защита на личните данни ↗</a></li><li><a href={href("/politika-za-poveritelnost/")}>Как Vdiga обработва данните от този сайт и формите за запитване ↗</a></li></ul>
    </div>
  </section>

  <section class="section" id="otgovori"><div class="container faq-grid"><div><p class="eyebrow">чести въпроси</p><h2>Кратки отговори за AI рецепционист и GDPR.</h2></div><FAQ items={faqs} /></div></section>
  <section class="section band"><div class="container"><OnboardingForm title="Обсъдете конкретната задача с нас." lead="Ще ви кажем каква конфигурация на Vdiga можем да предложим и каква техническа информация можем да предоставим. За индивидуалното правно основание потърсете вашия юрист или длъжностно лице по защита на данните." businessPlaceholder="Например дентална клиника, медицински център или салон" callProblemPlaceholder="Например: записване на часове, аудиозапис или здравни данни" /></div></section>
</BaseLayout>

<style>
  .gdpr-hero{background:linear-gradient(135deg,#f3f7f0,#fafaf7 65%,#eaf2e8)}.gdpr-hero-content,.article-width{max-width:940px}.gdpr-hero h1{max-width:18ch;color:var(--ink);font-size:clamp(2.65rem,4.4vw,4.35rem);line-height:1.03}.gdpr-hero .answer-block{max-width:850px;color:var(--ink-soft)}.gdpr-hero .btn-secondary{border-color:var(--ink);color:var(--ink)}.article-width h2{max-width:18ch}.article-width>p{max-width:800px;color:var(--ink-soft)}.article-width .lead{color:var(--ink);font-size:1.24rem;font-weight:700}.example-flow{display:grid;gap:0;margin:38px 0;border-top:2px solid var(--ink)}.example-flow div{display:grid;grid-template-columns:260px 1fr;gap:30px;padding:22px 0;border-bottom:1px solid var(--line)}.example-flow p{margin:0;color:var(--ink-soft)}.plain-note{max-width:820px;margin-top:34px;padding:20px 24px;border-left:4px solid var(--answer-deep);background:var(--paper);color:var(--ink-soft)}.plain-note strong{color:var(--ink)}.disclosure-section{background:var(--ink);color:var(--paper)}.disclosure-section h2{color:var(--paper)}.disclosure-section p{color:rgba(250,250,247,.78)}blockquote{margin:34px 0;padding:28px;border-left:5px solid var(--answer);background:rgba(255,255,255,.08);font-size:1.35rem;font-weight:750;line-height:1.5}.health-section{background:#edf3ea}.sector-links{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:34px}.sector-links a{display:flex;justify-content:space-between;padding:18px 0;border-bottom:2px solid var(--ink);font-weight:800}.contract-questions{margin:40px 0 0;padding:0;list-style:none;counter-reset:item}.contract-questions li{display:grid;grid-template-columns:minmax(250px,.8fr) 1.2fr;gap:36px;padding:24px 0;border-top:1px solid var(--line);counter-increment:item}.contract-questions strong::before{margin-right:12px;color:var(--answer-deep);font-family:var(--mono);content:"0" counter(item)}.contract-questions span{color:var(--ink-soft)}.sources-section{background:#e8eee5}.source-list{display:grid;gap:14px;margin-top:28px;padding:0;list-style:none}.source-list a{display:block;padding:15px 0;border-bottom:1px solid rgba(8,29,17,.2);font-weight:750;text-decoration:underline;text-decoration-color:var(--answer-deep);text-underline-offset:4px}.faq-grid{display:grid;grid-template-columns:.8fr 1.2fr;gap:70px}.faq-grid h2{max-width:13ch}
  @media(max-width:800px){.gdpr-hero h1{max-width:100%;font-size:clamp(2.15rem,9.4vw,2.5rem);overflow-wrap:anywhere}.gdpr-hero .button-row{display:grid}.gdpr-hero .btn{width:100%;white-space:normal}.example-flow div,.contract-questions li,.sector-links,.faq-grid{grid-template-columns:1fr;gap:8px}.example-flow strong{color:var(--answer-deep)}blockquote{margin-inline:0;padding:22px 18px;font-size:1.12rem}.sector-links{gap:12px}.contract-questions li{gap:10px}}
</style>
