---
import BaseLayout from "../layouts/BaseLayout.astro";
import CallCard from "../components/CallCard.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { articleSchema, faqSchema } from "../data/schema";

const faqs = [
  {
    question: "Защо демо номерът още не е публичен?",
    answer:
      "Vdiga няма да показва фалшив номер. Първо минават тестови разговори на български. После публичният номер става основният тест за продукта.",
  },
  {
    question: "Какво трябва да чуя в демото?",
    answer:
      "Трябва да чуете представяне още в началото, естествен български, правилни въпроси, записване на час и нормален край на разговора.",
  },
  {
    question: "Ще казва ли, че е AI?",
    answer:
      "Да. Vdiga се представя като AI асистент. Клиентът трябва да знае с кого говори още в началото.",
  },
  {
    question: "Какво е AI receptionist на английски?",
    answer:
      "Това е AI receptionist или AI answering service. На български използваме AI рецепционист.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="AI рецепционист демо — чуйте разговор | Vdiga"
  description="Чуйте AI рецепционист демо на български. Вижте как трябва да започва разговорът и кога човек поема сложния случай."
  path="/demo"
  schemas={[faqSchema(faqs), articleSchema("AI рецепционист демо — Vdiga", "/demo", "Как се тества AI рецепционист на български преди публичен старт.")]}
>
  <section class="hero">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">AI рецепционист демо</p>
        <h1>Чуйте AI рецепционист на български.</h1>
        <p class="answer-block">
          Към юли 2026 г. демото на Vdiga показва примерен AI (изкуствен интелект) рецепционист. Чувате начало на разговор, уточняващи въпроси, записване на час и пренасочване към човек при сложен случай.
        </p>
        <p class="lead">
          Първо слушате разговора. После гледате цената, настройката и реалния номер.
        </p>
        <div class="button-row hero-actions">
          <a class="btn btn-primary" href="#test">Проверете критериите</a>
          <a class="btn btn-secondary" href={href("/tseni")}>Вижте планове</a>
        </div>
      </div>
      <CallCard />
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">сценарий</p>
        <h2>Как трябва да започва разговорът?</h2>
        <p>
          Началото трябва да е кратко и честно. Клиентът разбира къде се обажда, че говори с AI асистент и какво може да направи веднага.
        </p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Роля</th>
              <th>Примерна реплика</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>AI</td>
              <td>Здравейте, обаждате се на дентална клиника [име]. Аз съм AI асистент и мога да ви запиша час.</td>
            </tr>
            <tr>
              <td>Пациент</td>
              <td>Имате ли свободно утре следобед?</td>
            </tr>
            <tr>
              <td>AI</td>
              <td>Ще проверя свободните часове. За преглед ли е, или имате болка?</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section" id="test">
    <div class="container">
        <p class="eyebrow">преди публичен номер</p>
        <h2>Какво трябва да мине преди публичен номер?</h2>
      <div class="grid-3">
        <article class="feature">
          <h3>Естествен български</h3>
          <p>Имена, часове, квартали и прекъсвания трябва да звучат нормално за български клиент.</p>
        </article>
        <article class="feature">
          <h3>Правилни въпроси</h3>
          <p>AI асистентът пита за услуга, удобен час, име и спешност. Не води празен разговор.</p>
        </article>
        <article class="feature">
          <h3>Пренасочване към човек</h3>
          <p>Когато случаят е спешен или сложен, Vdiga не импровизира. Пренасочва или взема съобщение.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">чести въпроси</p>
        <h2>Какво трябва да знаете преди демото?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Демото трябва да звучи нормално." text="Ако гласът не издържи първия разговор, няма смисъл да го включвате към бизнеса си." />
</BaseLayout>
