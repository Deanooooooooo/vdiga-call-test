---
import BaseLayout from "../layouts/BaseLayout.astro";
import CallCard from "../components/CallCard.astro";
import PricingCards from "../components/PricingCards.astro";
import OnboardingForm from "../components/OnboardingForm.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { faqSchema, productSchema } from "../data/schema";
import { site, withBase as href } from "../data/site";

const faqs = [
  {
    question: "Какво е AI рецепционист?",
    answer:
      "AI рецепционист е телефонен асистент, който вдига вместо вас. Той пита за услугата, проверява свободни часове и записва клиента според правилата ви.",
  },
  {
    question: "Vdiga говори ли на български?",
    answer: "Да. Vdiga разговаря на естествен български.",
  },
  {
    question: "Кой стои зад Vdiga?",
    answer: `Vdiga се разработва от ${site.legalName}, София. Това е правният оператор за сайта, офертите, договорите, фактурите и политиките.`,
  },
  {
    question: "Как се казва това на английски?",
    answer:
      "На английски най-често се използват AI receptionist, AI answering service и voice AI assistant. На български използваме AI рецепционист.",
  },
];
---

<BaseLayout
  title="AI рецепционист — обаждания и часове | Vdiga"
  description="Vdiga е AI рецепционист на български. Вдига телефона, записва часове и праща кратка информация след разговора."
  path="/"
  schemas={[faqSchema(faqs), productSchema()]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AI рецепционист на български</p>
        <h1><span>AI рецепционист,</span><span>който Vdiga</span><span>вместо вас.</span></h1>
        <p class="hero-sub">
          Vdiga отговаря, записва часове и ви оставя най-важното след разговора: кой се обади, какво поиска и какво е уговорено.
        </p>
        <div class="button-row hero-actions">
          <a class="btn btn-primary" href="#zayavka"><span class="hero-cta-wide">Vdiga за вашия бизнес</span><span class="hero-cta-short">Vdiga за вашия бизнес</span></a>
          <a class="btn btn-secondary" href="#planove">Вижте плановете</a>
        </div>
        <p class="hero-cta-note">Ще ви кажем какво може да поема и колко ще струва.</p>
      </div>
      <CallCard />
    </div>
  </section>

  <section class="section band outcome-section" id="propusnato-obazhdane">
    <div class="container">
      <div class="outcome-head">
        <div class="outcome-head-copy">
          <p class="eyebrow">цената на пропуснатия разговор</p>
          <h2>Какво струва едно пропуснато обаждане?</h2>
          <p class="outcome-intro">
            Клиентът звъни, защото иска час, резервация, поръчка или оферта. Ако никой не вдигне, често звъни на следващия бизнес.
          </p>
        </div>
        <div class="outcome-person" aria-hidden="true">
          <span class="outcome-person-circle"></span>
          <span class="outcome-person-arc"></span>
          <img
            src={href("/assets/vdiga-person-cutout-v1.png")}
            alt="Служителка разговаря с клиент по телефона"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
      <div class="grid-3 outcome-grid">
        <article class="feature outcome-feature">
          <h3>Клиентът търси решение сега</h3>
          <p>
            Когато не вдигнете, той не знае дали ще му се обадите след пет минути или утре. Затваря и продължава да търси.
          </p>
        </article>
        <article class="feature outcome-feature">
          <h3>Vdiga вдига вместо вас</h3>
          <p>
            Докато работите, шофирате или сте с друг клиент, Vdiga отговаря и пита за всичко необходимо.
          </p>
        </article>
        <article class="feature outcome-feature">
          <h3>Получавате готовата заявка</h3>
          <p>
            Виждате кой се е обадил, какво иска и какво е уговорено. Можете да действате, без първо да връщате пропуснато обаждане.
          </p>
        </article>
      </div>
      <p class="outcome-close">
        Клиентът получава отговор, когато е готов да купи, резервира или запише час. Вижте <a href={href("/kak-raboti/")}>как работи AI рецепционистът</a> от обаждането до готовата заявка.
      </p>
    </div>
  </section>

  <section class="section industry-section" id="kude-si-struva">
    <div class="container">
      <div class="industry-head">
        <div>
          <p class="eyebrow">решения по индустрии</p>
          <h2>Телефонът звъни различно във всеки бизнес.</h2>
        </div>
        <p>Затова Vdiga не работи с един общ сценарий. Графикът, въпросите и моментът за намеса на човек се настройват според реалната работа.</p>
      </div>
      <div class="industry-grid" aria-label="AI телефонни решения по индустрии">
        <a class="industry-card dental rev" style="--d:0s" href={href("/ai-retseptsionist-dentalna-klinika/")}>
          <span class="industry-index">01 / Дентална грижа</span>
          <div class="industry-card-copy"><h3>AI рецепционист за дентална клиника</h3><p>Записва разрешените услуги, докато стоматологът, асистентът или рецепцията са с пациент.</p></div>
          <div class="industry-route" aria-label="Работен поток"><span>Пациент</span><i>→</i><span>Услуга</span><i>→</i><span>Лекар</span><i>→</i><strong>Час</strong></div>
          <div class="industry-link"><span>Вижте решението</span><b aria-hidden="true">↗</b></div>
        </a>
        <a class="industry-card medical rev" style="--d:.06s" href={href("/ai-retseptsionist-meditsinski-tsentar/")}>
          <span class="industry-index">02 / Медицински услуги</span>
          <div class="industry-card-copy"><h3>AI рецепционист за медицински център</h3><p>Насочва към точната специалност, лекар и обект, без да поема медицинската преценка.</p></div>
          <div class="industry-route" aria-label="Работен поток"><span>Пациент</span><i>→</i><span>Специалност</span><i>→</i><span>Обект</span><i>→</i><strong>Час</strong></div>
          <div class="industry-link"><span>Вижте решението</span><b aria-hidden="true">↗</b></div>
        </a>
        <a class="industry-card beauty rev" style="--d:.12s" href={href("/ai-retseptsionist-salon-za-krasota/")}>
          <span class="industry-index">03 / Красота и грижа</span>
          <div class="industry-card-copy"><h3>AI рецепционист за салон за красота</h3><p>Съобразява услугата, специалиста и продължителността, докато екипът работи с клиенти.</p></div>
          <div class="industry-route" aria-label="Работен поток"><span>Клиент</span><i>→</i><span>Услуга</span><i>→</i><span>Специалист</span><i>→</i><strong>Час</strong></div>
          <div class="industry-link"><span>Вижте решението</span><b aria-hidden="true">↗</b></div>
        </a>
        <a class="industry-card taxi rev" style="--d:.18s" href={href("/ai-dispecher-za-taksimetrova-kompaniya/")}>
          <span class="industry-index">04 / Таксиметрови услуги</span>
          <div class="industry-card-copy"><h3>AI диспечер за таксиметрова компания</h3><p>Приема телефонната поръчка и подава адреса, маршрута и изискванията към диспечерската система.</p></div>
          <div class="industry-route" aria-label="Работен поток"><span>Адрес</span><i>→</i><span>Автомобил</span><i>→</i><span>Система</span><i>→</i><strong>Поръчка</strong></div>
          <div class="industry-link"><span>Вижте enterprise решението</span><b aria-hidden="true">↗</b></div>
        </a>
      </div>
    </div>
  </section>

  <section class="section band" id="planove">
    <div class="container">
      <div class="pricing-heading">
        <div>
          <p class="eyebrow">изберете план за входящите си обаждания</p>
          <h2>Колко струва AI рецепционист от Vdiga?</h2>
        </div>
        <p>Изберете според минутите входящи разговори, които искате Vdiga да поема. Ако не знаете колко са, ще ги изчислим с вас.</p>
      </div>
      <PricingCards />
      <OnboardingForm />
      <section class="setup-trust" aria-labelledby="setup-trust-title">
        <div>
          <p class="eyebrow">какво става след заявката</p>
          <h2 id="setup-trust-title">Първо уточняваме всичко. После решавате.</h2>
        </div>
        <div class="setup-trust-grid">
          <article>
            <h3>Разговаряме</h3>
            <p>Разбираме какви входящи обаждания получавате и какво трябва да прави Vdiga.</p>
          </article>
          <article>
            <h3>Изпращаме предложение</h3>
            <p>Виждате какво ще поема Vdiga, как ще бъде настроен и колко ще струва.</p>
          </article>
          <article>
            <h3>Вие решавате</h3>
            <p>Не създаваме профил и не започваме абонамент, преди да потвърдите.</p>
          </article>
        </div>
      </section>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">чести въпроси</p>
        <h2>Какво искат да знаят клиентите преди да започнат?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA
    title="Нека Vdiga вдига следващото обаждане."
    text="Кажете ни как работи бизнесът ви. Ще обсъдим какво може да поема Vdiga и колко ще струва."
    buttonLabel="Vdiga за вашия бизнес"
    buttonHref="#zayavka"
  />
</BaseLayout>
