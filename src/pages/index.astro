---
import BaseLayout from "../layouts/BaseLayout.astro";
import CallCard from "../components/CallCard.astro";
import PricingCards from "../components/PricingCards.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { articleSchema, faqSchema, productSchema } from "../data/schema";

const faqs = [
  {
    question: "Какво е AI рецепционист?",
    answer:
      "AI рецепционист е телефонен асистент с изкуствен интелект. Той отговаря на входящи обаждания, задава точните въпроси и записва часове според правилата ви.",
  },
  {
    question: "Vdiga говори ли на български?",
    answer:
      "Да. Vdiga се прави за разговори на естествен български. Преди публичен номер минава тестови разговори с реални сценарии.",
  },
  {
    question: "Кой стои зад Vdiga?",
    answer:
      "Vdiga се разработва от Blast Off EOOD, София. Това е правният оператор за сайта, фактурите, условията и политиките.",
  },
  {
    question: "Как се казва това на английски?",
    answer:
      "На английски най-често се използват AI receptionist, AI answering service и voice AI assistant. Българският термин, който Vdiga използва, е AI рецепционист.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="AI рецепционист — Vdiga"
  description="Vdiga е AI рецепционист на български език за обаждания 24/7, записване на часове и обобщения след разговор."
  path="/"
  schemas={[faqSchema(faqs), productSchema(), articleSchema("AI рецепционист — Vdiga", "/", "AI рецепционист на български език за клиники, салони и услуги.")]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">входящо обаждане · vdiga е на линия</p>
        <h1>AI рецепционист, който вдига, когато вие не можете.</h1>
        <p class="hero-sub">
          Vdiga е AI (изкуствен интелект) рецепционист на български. Отговаря 24/7, записва часа директно в календара ви и праща кратко обобщение след разговора.
        </p>
        <div class="button-row hero-actions">
          <a class="btn btn-primary" href={href("/demo")}>Чуйте демото</a>
          <a class="btn btn-secondary" href={href("/tseni")}>Вижте цените</a>
        </div>
      </div>
      <CallCard />
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <p class="eyebrow">какво печелите</p>
      <h2>Какво става с обаждането, когато никой не вдигне?</h2>
      <div class="grid-3">
        <article class="feature">
          <h3>Vdiga отговаря</h3>
          <p>Приема входящото обаждане и казва ясно, че е AI асистент. Клиентът получава отговор вместо тишина.</p>
        </article>
        <article class="feature">
          <h3>Vdiga записва</h3>
          <p>Пита за услуга, име и удобен час. При свободен слот записва клиента според правилата ви.</p>
        </article>
        <article class="feature">
          <h3>Vdiga обобщава</h3>
          <p>След разговора получавате кратко обобщение: кой се обади, какво поиска и какво е направено.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">подходящи бизнеси</p>
        <h2>Къде Vdiga има най-много смисъл?</h2>
        <p>
          Vdiga е най-полезна там, където пропуснатото обаждане често значи пропуснат час. Най-силните първи случаи са дентални клиники, медицински центрове и салони.
        </p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Бизнес</th>
              <th>Какво пита клиентът</th>
              <th>Какво прави Vdiga</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Дентална клиника</td>
              <td>„Имате ли час утре?“</td>
              <td>Проверява календара и записва час с потвърждение.</td>
            </tr>
            <tr>
              <td>Медицински център</td>
              <td>„Кога приема докторът?“</td>
              <td>Отговаря по вашите правила и прехвърля сложните случаи към човек.</td>
            </tr>
            <tr>
              <td>Салон за красота</td>
              <td>„Свободно ли е в петък?“</td>
              <td>Намира свободен час, записва го и праща обобщение.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <p class="eyebrow">цени</p>
      <h2>Колко струва AI рецепционистът?</h2>
      <PricingCards />
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">чести въпроси</p>
        <h2>Какво питат собствениците преди първия тест?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Чуйте как ще звучи вашият рецепционист." text="Един примерен разговор казва повече от всяка дълга страница." />
</BaseLayout>
