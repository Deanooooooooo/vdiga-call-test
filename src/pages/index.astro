---
import BaseLayout from "../layouts/BaseLayout.astro";
import CallCard from "../components/CallCard.astro";
import PricingCards from "../components/PricingCards.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { articleSchema, faqSchema, productSchema } from "../data/schema";

const faqs = [
  {
    question: "Какво е AI рецепционист?",
    answer:
      "AI рецепционист е телефонен асистент, който отговаря на входящи обаждания, задава уточняващи въпроси и записва часове според правилата на бизнеса ви.",
  },
  {
    question: "Vdiga говори ли на български?",
    answer:
      "Vdiga се планира като български-first AI рецепционист. Публичният старт ще мине през тестови разговори, за да се провери естественото звучене на български.",
  },
  {
    question: "Кой стои зад Vdiga?",
    answer:
      "Vdiga се разработва от Blast Off EOOD, София. Това е реалният правен оператор за сайта, фактурите, условията и политиките до отделно дружество след валидация.",
  },
  {
    question: "Как се казва това на английски?",
    answer:
      "На английски най-често се използват AI receptionist, AI answering service и voice AI assistant. Българският термин, който Vdiga използва, е AI рецепционист.",
  },
];
---

<BaseLayout
  title="AI рецепционист — Vdiga"
  description="Vdiga е AI рецепционист на български език за обаждания 24/7, записване на часове и обобщения след разговор."
  path="/"
  schemas={[faqSchema(faqs), productSchema(), articleSchema("AI рецепционист — Vdiga", "/", "AI рецепционист на български език за клиники, салони и услуги.")]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">AI рецепционист на български</p>
        <h1>AI рецепционист, който вдига 24/7 и записва часове.</h1>
        <p class="hero-sub">
          Vdiga приема входящите обаждания, пита като обучен рецепционист, записва час в календара и праща ясно обобщение след всеки разговор.
        </p>
        <div class="button-row hero-actions">
          <a class="btn btn-primary" href="/demo">Чуйте демото</a>
          <a class="btn btn-secondary" href="/tseni">Вижте цените</a>
        </div>
        <div class="hero-proof">
          <span><strong>24/7</strong> отговор</span>
          <span><strong>75 €</strong> старт</span>
          <span><strong>без</strong> фалшив номер</span>
        </div>
      </div>
      <CallCard />
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <p class="eyebrow">пропуснато срещу отговорено</p>
      <h2>Как Vdiga превръща звъненето в записан час?</h2>
      <div class="grid-3">
        <article class="feature">
          <h3>Отговаря веднага</h3>
          <p>AI рецепционистът приема обаждането, представя се ясно и започва разговора по правилата на бизнеса ви.</p>
        </article>
        <article class="feature">
          <h3>Събира правилните детайли</h3>
          <p>Пита за услуга, удобен час, име и спешност, вместо да оставя собственика да връща пропуснати номера.</p>
        </article>
        <article class="feature">
          <h3>Записва и обобщава</h3>
          <p>Когато има свободен час, записва клиента. След това праща ясно резюме: кой звъня, какво поиска и какво стана.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">нишови сценарии</p>
        <h2>Къде Vdiga има най-много смисъл?</h2>
        <p>
          Най-силен е при бизнеси, където хората звънят, за да запазят час, да проверят свободен слот или да получат бърз отговор. Първите шаблони са за дентални клиники, медицински центрове и салони за красота.
        </p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Бизнес</th>
              <th>Какво пита клиентът</th>
              <th>Какво прави Vdiga</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Дентална клиника</td>
              <td>„Имате ли час утре?“</td>
              <td>Проверява свободните часове, записва посещение и изпраща потвърждение.</td>
            </tr>
            <tr>
              <td>Медицински център</td>
              <td>„Кога приема докторът?“</td>
              <td>Отговаря по зададени правила и прехвърля сложните случаи към човек.</td>
            </tr>
            <tr>
              <td>Салон за красота</td>
              <td>„Свободно ли е в петък?“</td>
              <td>Намира свободен час, записва клиента и праща обобщение към екипа.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <p class="eyebrow">цени</p>
      <h2>Колко струва AI рецепционист за входящи обаждания?</h2>
      <PricingCards />
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">чести въпроси</p>
        <h2>Въпросите, които нормално идват преди първия тест</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Първо чуйте как отговаря AI рецепционистът." text="Ако разговорът звучи естествено, цената и настройката стават лесен следващ разговор." />
</BaseLayout>
