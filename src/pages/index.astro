---
import BaseLayout from "../layouts/BaseLayout.astro";
import CallCard from "../components/CallCard.astro";
import PricingCards from "../components/PricingCards.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { articleSchema, faqSchema, productSchema } from "../data/schema";

const faqs = [
  {
    question: "Какво е AI рецепционист?",
    answer:
      "AI рецепционист е телефонен асистент, който вдига вместо вас. Той пита за услугата, проверява свободни часове и записва клиента според правилата ви.",
  },
  {
    question: "Vdiga говори ли на български?",
    answer:
      "Да. Vdiga се прави за разговори на естествен български. Публичният номер ще излезе само след достатъчно добри тестови разговори.",
  },
  {
    question: "Кой стои зад Vdiga?",
    answer:
      "Vdiga се разработва под Blast Off EOOD, София. Това е правният оператор за сайта, фактурите, условията и политиките.",
  },
  {
    question: "Как се казва това на английски?",
    answer:
      "На английски най-често се използват AI receptionist, AI answering service и voice AI assistant. На български използваме AI рецепционист.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="AI рецепционист — обаждания и часове | Vdiga"
  description="Vdiga е AI рецепционист на български. Вдига телефона, записва часове и праща кратка информация след разговора."
  path="/"
  schemas={[faqSchema(faqs), productSchema(), articleSchema("AI рецепционист — Vdiga", "/", "AI рецепционист на български език за клиники, салони и услуги.")]}
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">AI рецепционист на български</p>
        <h1><span>AI рецепционист,</span><span>който Vdiga</span><span>вместо вас.</span></h1>
        <p class="hero-sub">
          Vdiga отговаря, записва часове и ви оставя най-важното след разговора: кой се обади, какво поиска и какво е уговорено.
        </p>
        <div class="button-row hero-actions">
          <a class="btn btn-primary" href={href("/demo")}>Чуйте разговор</a>
          <a class="btn btn-secondary" href={href("/tseni")}>Вижте планове</a>
        </div>
      </div>
      <CallCard />
    </div>
  </section>

  <section class="section band outcome-section" id="propusnato-obazhdane">
    <div class="container">
      <p class="eyebrow">пропуснато обаждане</p>
      <h2>Какво струва едно пропуснато обаждане?</h2>
      <p class="outcome-intro">
        Понякога е един записан час. Понякога е поръчка. Понякога е клиент, който вече говори с конкурента ви.
        Повечето хора не чакат някой да им върне обаждане. Затварят и звънят на следващия. Vdiga не позволява това да се случи.
      </p>
      <div class="grid-3 outcome-grid">
        <article class="feature outcome-feature">
          <span class="outcome-step">01</span>
          <h3>Всеки получава отговор.</h3>
          <p>
            След работно време, в натоварен момент или когато целият екип е зает, Vdiga вдига телефона вместо вас.
            Разговаря на български, представя се като AI асистент и започва разговора веднага. Клиентът не слуша свободен сигнал.
            Не чака. Не си тръгва.
          </p>
        </article>
        <article class="feature outcome-feature">
          <span class="outcome-step">02</span>
          <h3>Всяко обаждане става заявка.</h3>
          <p>
            Vdiga разбира защо се обаждат, записва име и телефон и следва начина, по който работи вашият бизнес.
            Час, резервация, поръчка, оглед, обратно обаждане или друга заявка. Всеки разговор завършва с конкретен резултат,
            вместо с пропусната възможност.
          </p>
        </article>
        <article class="feature outcome-feature">
          <span class="outcome-step">03</span>
          <h3>Екипът знае какво да направи.</h3>
          <p>
            След разговора получавате най-важното: кой се е обадил, какво иска, какво е обещано и има ли спешност.
            Вместо списък с пропуснати повиквания, получавате подредени задачи и следващи действия.
          </p>
        </article>
      </div>
      <p class="outcome-close">Телефонът звъни. Клиентът получава отговор. Бизнесът ви не губи възможности.</p>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">къде има смисъл</p>
        <h2>Къде Vdiga има най-много смисъл?</h2>
        <p>
          Vdiga е най-полезна там, където пропуснатото обаждане значи празен час. Първите силни случаи са дентални клиники, медицински центрове и салони.
        </p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Бизнес</th>
              <th>Какво пита клиентът</th>
              <th>Какво прави Vdiga</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Дентална клиника</td>
              <td>„Имате ли час утре?“</td>
              <td>Проверява календара и записва час с потвърждение.</td>
            </tr>
            <tr>
              <td>Медицински център</td>
              <td>„Кога приема докторът?“</td>
              <td>Отговаря по вашите правила и пренасочва сложните случаи към човек.</td>
            </tr>
            <tr>
              <td>Салон за красота</td>
              <td>„Свободно ли е в петък?“</td>
              <td>Намира свободен час, записва го и ви праща какво е уговорено.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <p class="eyebrow">AI рецепционист цена</p>
      <h2>Колко струва AI рецепционист?</h2>
      <PricingCards />
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">чести въпроси</p>
        <h2>Какво питат собствениците преди тест?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Чуйте как звучи вашият рецепционист." text="Ако разговорът звучи нормално, следващата стъпка е лесна." />
</BaseLayout>
