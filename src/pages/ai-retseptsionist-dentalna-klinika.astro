---
import BaseLayout from "../layouts/BaseLayout.astro";
import CallCard from "../components/CallCard.astro";
import FAQ from "../components/FAQ.astro";
import OnboardingForm from "../components/OnboardingForm.astro";
import PricingCards from "../components/PricingCards.astro";
import { faqSchema, serviceSchema } from "../data/schema";
import { withBase as href } from "../data/site";

const path = "/ai-retseptsionist-dentalna-klinika/";
const title = "AI рецепционист за дентална клиника | Vdiga";
const description = "AI рецепционист за дентална клиника: приема обаждания, записва пациенти по правилата на клиниката и предава спешните случаи към екипа.";

const faqs = [
  {
    question: "Какво може да поема AI рецепционистът в дентална клиника?",
    answer: "Може да приема обаждания за нов час, промяна или отказ, работно време, адрес и услуги. При болка, травма, усложнение или медицински въпрос предава случая на екипа на клиниката.",
  },
  {
    question: "Може ли Vdiga да записва директно в календара?",
    answer: "Да, когато клиниката е определила кои услуги, лекари и свободни часове могат да се предлагат. Ако е нужна преценка от екипа, Vdiga взема име, телефон и причина за обаждането, без да обещава час.",
  },
  {
    question: "Дава ли медицински съвет или диагноза?",
    answer: "Не. Vdiga не поставя диагноза и не препоръчва лечение. Медицинските въпроси, спешните симптоми и случаите извън одобрената информация се насочват към екипа на клиниката.",
  },
  {
    question: "Може ли да работи, когато рецепцията е заета или клиниката е затворена?",
    answer: "Да. Vdiga може да поема разговори при заета линия, едновременно позвъняване, извън работно време или по график, определен от клиниката.",
  },
  {
    question: "Подходящ ли е за самостоятелен стоматолог без рецепция?",
    answer: "Да. Vdiga може да отговаря, докато стоматологът и асистентът са с пациент, да записва разрешените услуги и да изпраща обобщение след разговора. Така лечението не се прекъсва за всяко позвъняване.",
  },
  {
    question: "Колко струва AI рецепционист за дентална клиника?",
    answer: "Плановете на Vdiga започват от 97 евро на месец без ДДС. Цената зависи от минутите входящи разговори, броя телефонни линии и начина на записване на часове.",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  path={path}
  pageClass="dental-page"
  schemas={[
    serviceSchema("AI рецепционист за дентална клиника", path, description),
    faqSchema(faqs),
  ]}
>
  <section class="hero dental-hero">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">AI рецепционист за дентална клиника</p>
        <h1>AI рецепционист за дентална клиника</h1>
        <p class="answer-block">
          Vdiga поема обажданията, когато стоматологът, асистентът или рецепцията не могат. Записва пациенти според графика и изпраща кой се е обадил и какво е уговорено. При болка, травма или медицински въпрос предава случая на екипа.
        </p>
        <p class="lead">За самостоятелен кабинет, натоварена рецепция или клиника с няколко телефонни линии.</p>
        <div class="button-row hero-actions">
          <a class="btn btn-primary" href="#zayavka">Обсъдете вашата клиника</a>
          <a class="btn btn-secondary" href={href("/demo/")}>Чуйте разговор</a>
        </div>
      </div>
      <CallCard />
    </div>
  </section>

  <section class="section band">
    <div class="container">
      <div class="dental-section-head">
        <div>
          <p class="eyebrow">болката зад пропуснатия разговор</p>
          <h2>Телефонът звъни точно когато никой не може да вдигне.</h2>
        </div>
        <p>Стоматологът работи. Асистентът е до стола. Рецепцията обслужва пациент или говори по друга линия. За обаждащия се това означава само едно: никой не отговаря.</p>
      </div>
      <div class="grid-3 dental-pains">
        <article class="feature">
          <span class="dental-number">01</span>
          <h3>Лечението не може да спира</h3>
          <p>Самостоятелният стоматолог и асистентът не могат да прекъсват работа при всяко позвъняване. Но новият пациент може да не звънне втори път.</p>
        </article>
        <article class="feature">
          <span class="dental-number">02</span>
          <h3>Една рецепция, няколко задачи</h3>
          <p>Пациент е пред бюрото, друг плаща, а втора линия звъни. Обаждането се губи не защото няма рецепция, а защото тя вече е заета.</p>
        </article>
        <article class="feature">
          <span class="dental-number">03</span>
          <h3>Повече кабинети, повече линии</h3>
          <p>При няколко лекари и обекта разговорите трябва да стигат до точния график и екип. Един общ списък с пропуснати номера не е достатъчен.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section dental-models-section">
    <div class="container">
      <div class="dental-section-head">
        <div>
          <p class="eyebrow">три начина на работа</p>
          <h2>За кабинет без рецепция, заета рецепция или клиника с няколко линии.</h2>
        </div>
        <p>Vdiga може да вдига вместо стоматолога, да помага на заета рецепция или да обслужва няколко линии. Настройката зависи от това кой отговаря сега и кога обажданията остават без отговор.</p>
      </div>
      <PricingCards
        segments={[
          {
            name: "Самостоятелен стоматолог",
            description: "Vdiga вдига, докато стоматологът и асистентът са с пациент, записва разрешените услуги и изпраща обобщение.",
          },
          {
            name: "Клиника със заета рецепция",
            description: "Vdiga поема при заета линия, в натоварените часове и извън работно време, без да заменя рецепциониста.",
          },
          {
            name: "Голяма дентална клиника",
            description: "За няколко кабинета, телефонни линии или обекта с различни лекари, графици и правила.",
          },
        ]}
      />
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">какво поема Vdiga</p>
        <h2>Записването на час е за Vdiga. Медицинската преценка остава за екипа.</h2>
        <p class="dental-intro">Vdiga поема повтарящите се въпроси и записването. Стоматологът, асистентът или рецепцията поемат всичко, което изисква медицинска преценка.</p>
        <ul class="split-list">
          <li>нов пациент и причина за посещението</li>
          <li>заявка за преглед или профилактика</li>
          <li>промяна или отказ на съществуващ час</li>
          <li>работно време, адрес и одобрена информация за услуги</li>
          <li>име, телефон и кратко резюме към екипа</li>
        </ul>
      </div>
      <div class="dental-boundary">
        <p class="eyebrow">кога разговорът отива към човек</p>
        <h3>Vdiga не поставя диагноза.</h3>
        <p>При болка, подуване, кървене, травма, усложнение след лечение или въпрос, който изисква медицинска преценка, асистентът следва одобрения ред за ескалация.</p>
        <div class="boundary-flow" aria-label="Как се предава медицински случай">
          <span>Чува причината за обаждането</span>
          <span>Взема име и телефон</span>
          <span>Уведомява екипа</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">примерен работен поток</p>
        <h2>От „Имате ли час?“ до записан преглед.</h2>
        <ol class="dental-steps">
          <li><span>1</span><div><strong>Пита за какво се обажда пациентът</strong><p>Нов час, промяна, информация или връзка с екипа.</p></div></li>
          <li><span>2</span><div><strong>Проверява услугата и графика</strong><p>Лекар, продължителност и свободни часове.</p></div></li>
          <li><span>3</span><div><strong>Записва или предава</strong><p>Потвърждава часа или изпраща име, телефон и причина за обаждането.</p></div></li>
          <li><span>4</span><div><strong>Изпраща обобщение</strong><p>Екипът вижда кой се е обадил и какво е уговорено.</p></div></li>
        </ol>
      </div>
      <div class="dental-dialogue">
        <p class="dialogue-label">примерен разговор</p>
        <div class="bubble ai"><strong>Vdiga</strong><p>Здравейте, обаждате се в денталната клиника. Аз съм AI асистент. Как мога да помогна?</p></div>
        <div class="bubble patient"><strong>Пациент</strong><p>Искам час за профилактичен преглед след работа.</p></div>
        <div class="bubble ai"><strong>Vdiga</strong><p>Мога да проверя свободните часове след 17:30. Имате ли предпочитан ден или лекар?</p></div>
        <div class="dialogue-result"><span>След разговора</span><strong>Часът е записан, а екипът получава обобщение</strong></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="dental-section-head">
        <div>
          <p class="eyebrow">настройка за конкретната клиника</p>
          <h2>Клиниката решава какво може да казва и записва Vdiga.</h2>
        </div>
        <p>Преди старта описваме услугите, лекарите, графиците, продължителността на часовете, информацията за пациенти и случаите, които никога не трябва да се автоматизират.</p>
      </div>
      <div class="dental-control-grid">
        <article class="dental-control-card">
          <div class="control-icon" aria-hidden="true">01</div>
          <p class="control-label">Записване</p>
          <h3>Кои часове може да предлага?</h3>
          <p>Клиниката избира услугите, лекарите, продължителността и часовете. Vdiga не предлага нищо извън тях.</p>
          <div class="control-owner"><span>Решението остава при</span><strong>клиниката</strong></div>
        </article>
        <article class="dental-control-card dark">
          <div class="control-icon" aria-hidden="true">02</div>
          <p class="control-label">Медицински случай</p>
          <h3>Кога трябва да се намеси човек?</h3>
          <p>Болка, травма, усложнение и въпрос за лечение се предават на екипа. Vdiga не поставя диагноза.</p>
          <div class="control-owner"><span>Преценката остава при</span><strong>стоматолога</strong></div>
        </article>
        <article class="dental-control-card">
          <div class="control-icon" aria-hidden="true">03</div>
          <p class="control-label">Телефонни линии</p>
          <h3>Кога да отговаря Vdiga?</h3>
          <p>Постоянно, при заета линия, след определен брой позвънявания или извън работно време.</p>
          <div class="control-owner"><span>Графикът се избира от</span><strong>клиниката</strong></div>
        </article>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">бизнес резултатът</p>
        <h2>Целта е повече приети обаждания и повече записани часове.</h2>
        <p class="dental-intro">Vdiga има смисъл, когато намалява пропуснатите обаждания и позволява на стоматолога, асистента и рецепцията да останат при пациента.</p>
        <p>Следите колко обаждания са приети, колко часа са записани, колко случая са предадени на екипа и в кои часове телефонът е най-натоварен.</p>
        <div class="button-row">
          <a class="btn btn-primary" href={href("/tseni/")}>Вижте планове от 97 €</a>
        </div>
      </div>
      <div class="dental-metrics">
        <div><strong>Приети</strong><span>обаждания по час и ден</span></div>
        <div><strong>Завършени</strong><span>записвания и заявки</span></div>
        <div><strong>Предадени</strong><span>случаи към екипа</span></div>
        <div><strong>Натоварени часове</strong><span>кога звънят най-много пациенти</span></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">чести въпроси</p>
        <h2>Какво искат да знаят денталните клиники?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <section class="section band dental-contact">
    <div class="container">
      <OnboardingForm
        title="Вижте как Vdiga ще работи за вашата клиника."
        lead="Оставете телефон. Ще обсъдим кога обажданията остават без отговор, кои часове може да записва Vdiga и кога разговорът трябва да стигне до екипа."
        businessPlaceholder="Например Дентална клиника Дента"
        callProblemPlaceholder="Например: по време на лечение, при заета линия или след работно време"
      />
    </div>
  </section>
</BaseLayout>

<style>
  .dental-hero h1 { max-width: 12ch; }
  .dental-section-head { display: grid; grid-template-columns: 1.2fr .8fr; gap: 64px; align-items: end; margin-bottom: 48px; }
  .dental-section-head h2 { margin-bottom: 0; }
  .dental-section-head > p, .dental-intro { color: var(--ink-soft); font-size: 1.25rem; font-weight: 600; line-height: 1.55; }
  .dental-number { display: block; margin-bottom: 22px; color: var(--answer-deep); font-family: var(--mono); font-size: .86rem; font-weight: 800; }
  .dental-models-section { background: var(--paper); }
  .dental-models-section :global(.price-card-head h3) { max-width: 12ch; }
  .dental-models-section :global(.price-recommended) { margin: 2px 0 12px; color: var(--answer-deep); font-size: .84rem; font-weight: 700; }
  .dental-models-section :global(.price-recommended strong) { font-weight: 900; }
  .dental-boundary { padding: 38px; border-radius: 18px; background: var(--ink); color: var(--paper); }
  .dental-boundary h3 { color: var(--paper); font-size: clamp(2rem, 3vw, 3rem); }
  .dental-boundary p { color: rgba(250,250,247,.78); }
  .boundary-flow { display: grid; gap: 10px; margin-top: 28px; }
  .boundary-flow span { padding: 13px 15px; border: 1px solid rgba(255,255,255,.16); border-radius: 10px; font-weight: 750; }
  .dental-steps { display: grid; gap: 22px; margin: 34px 0 0; padding: 0; list-style: none; }
  .dental-steps li { display: grid; grid-template-columns: 42px 1fr; gap: 16px; }
  .dental-steps li > span { display: grid; width: 42px; height: 42px; place-items: center; border-radius: 50%; background: var(--answer); color: #07120b; font-weight: 900; }
  .dental-steps strong { font-size: 1.16rem; }
  .dental-steps p { margin: 4px 0 0; color: var(--ink-soft); }
  .dental-dialogue { padding: 30px; border: 1px solid var(--line); border-radius: 20px; background: var(--paper); box-shadow: 0 26px 60px -42px rgba(8,29,17,.45); }
  .dialogue-label { color: var(--answer-deep); font-size: .78rem; font-weight: 850; letter-spacing: .12em; text-transform: uppercase; }
  .bubble { max-width: 88%; margin-top: 18px; padding: 16px 18px; border-radius: 16px; }
  .bubble p { margin: 5px 0 0; font-size: 1rem; line-height: 1.5; }
  .bubble.ai { background: #e6f7e9; }
  .bubble.patient { margin-left: auto; background: #ecebe5; }
  .dialogue-result { display: grid; gap: 4px; margin-top: 24px; padding-top: 18px; border-top: 1px solid var(--line); }
  .dialogue-result span { color: var(--answer-deep); font-size: .76rem; font-weight: 850; text-transform: uppercase; }
  .dental-control-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16px; }
  .dental-control-card { display: flex; min-height: 410px; flex-direction: column; padding: 30px; border-radius: 18px; background: #edf4ed; }
  .dental-control-card.dark { background: var(--ink); color: var(--paper); }
  .control-icon { display: grid; width: 44px; height: 44px; margin-bottom: 38px; place-items: center; border-radius: 50%; background: var(--answer); color: #07120b; font-family: var(--mono); font-size: .75rem; font-weight: 900; }
  .control-label { margin-bottom: 10px; color: var(--answer-deep); font-size: .76rem; font-weight: 850; letter-spacing: .08em; text-transform: uppercase; }
  .dental-control-card.dark .control-label { color: var(--answer); }
  .dental-control-card h3 { font-size: clamp(1.5rem, 2vw, 1.95rem); }
  .dental-control-card.dark h3 { color: var(--paper); }
  .dental-control-card > p:not(.control-label) { color: var(--ink-soft); font-size: 1.05rem; line-height: 1.55; }
  .dental-control-card.dark > p:not(.control-label) { color: rgba(250,250,247,.74); }
  .control-owner { display: grid; gap: 3px; margin-top: auto; padding-top: 20px; border-top: 1px solid rgba(8,29,17,.14); }
  .dental-control-card.dark .control-owner { border-top-color: rgba(255,255,255,.16); }
  .control-owner span { color: var(--ink-soft); font-size: .82rem; font-weight: 650; }
  .dental-control-card.dark .control-owner span { color: rgba(250,250,247,.58); }
  .control-owner strong { font-size: 1.18rem; }
  .dental-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .dental-metrics div { min-height: 150px; padding: 24px; border: 1px solid var(--line); border-radius: 16px; background: var(--paper); }
  .dental-metrics strong, .dental-metrics span { display: block; }
  .dental-metrics strong { margin-bottom: 10px; color: var(--ink); font-family: var(--disp); font-size: 1.45rem; }
  .dental-metrics span { color: var(--ink-soft); font-weight: 650; }
  @media (max-width: 800px) {
    .dental-section-head { grid-template-columns: 1fr; gap: 20px; }
    .dental-control-grid { grid-template-columns: 1fr; }
    .dental-control-card { min-height: 0; }
    .dental-boundary, .dental-dialogue { padding: 24px; }
    .dental-metrics { grid-template-columns: 1fr; }
    .dental-metrics div { min-height: 0; }
  }
</style>
