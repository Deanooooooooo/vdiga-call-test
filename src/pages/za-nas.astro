---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { site } from "../data/site";
import { articleSchema, faqSchema } from "../data/schema";

const faqs = [
  {
    question: "Vdiga отделна фирма ли е?",
    answer:
      "Не. На този етап Vdiga е продукт под Blast Off EOOD. Отделно OOD има смисъл след платени пилоти и реален приход.",
  },
  {
    question: "Защо не е създадена нова фирма още сега?",
    answer:
      "Новата фирма има смисъл след доказано търсене. Дотогава Blast Off EOOD дава правен оператор, фактуриране и публична отговорност.",
  },
  {
    question: "Кой преглежда съдържанието?",
    answer:
      "Публичните страници минават човешка редакция преди финално публикуване. Числата се публикуват само с източник или собствено проучване.",
  },
  {
    question: "Какво е Vdiga на английски?",
    answer:
      "Vdiga попада в категориите AI receptionist, AI answering service и voice AI assistant.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="За нас — Vdiga by Blast Off EOOD"
  description="Vdiga е AI рецепционист на български език, разработван от Blast Off EOOD, София."
  path="/za-nas"
  schemas={[faqSchema(faqs), articleSchema("За нас — Vdiga", "/za-nas", "Кой стои зад Vdiga и защо продуктът стартира под Blast Off EOOD.")]}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">За нас</p>
      <h1>Vdiga е AI рецепционист на български от Blast Off EOOD.</h1>
      <p class="answer-block">
        Към юли 2026 г. Vdiga е AI (изкуствен интелект) рецепционист, разработван от Blast Off EOOD, София. Продуктът стартира под съществуваща фирма, за да има реален оператор, фактуриране и ясна отговорност.
      </p>
      <p class="lead">
        Целта е проста: телефонен асистент, който вие можете да чуете, проверите и после да включите към бизнеса си.
      </p>
      <div class="button-row hero-actions">
        <a class="btn btn-primary" href={href("/demo")}>Чуйте демото</a>
        <a class="btn btn-secondary" href={href("/kak-raboti")}>Как работи</a>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Правен оператор</p>
        <h2>Защо Vdiga стартира под съществуваща фирма?</h2>
        <p>
          Клиентите търсят реална отговорност. Затова Vdiga започва под Blast Off EOOD за фактури, условия, поверителност и публична проверимост.
        </p>
        <p>
          Ако продуктът докаже търсене, може да се създаде отделно дружество и операциите да се прехвърлят чисто.
        </p>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Елемент</th>
              <th>Първа версия</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Марка</td>
              <td>Vdiga</td>
            </tr>
            <tr>
              <td>Юридически оператор</td>
              <td>{site.legalName}</td>
            </tr>
            <tr>
              <td>Локация</td>
              <td>{site.location}</td>
            </tr>
            <tr>
              <td>Бъдещо OOD</td>
              <td>след платени пилоти или ясен приход</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Автор и отговорност</p>
        <h2>Кой пише и поддържа страниците?</h2>
        <p>
          Съдържанието на Vdiga следва ясни правила: кратки изречения, без пълнеж, без измислени статистики и без преводно звучене.
        </p>
      </div>
      <div class="author-box">
        <div class="avatar">D</div>
        <div>
          <strong>{site.author.name}</strong>
          <p style="margin: 4px 0 0;">{site.author.role}. {site.author.bio}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">Чести въпроси</p>
        <h2>Какво трябва да е ясно преди публикуване?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Доверието започва преди първия разговор." text="Затова Vdiga показва кой стои зад продукта и какво вече може да се тества." />
</BaseLayout>
