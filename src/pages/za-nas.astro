---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { site } from "../data/site";
import { breadcrumbSchema, faqSchema, founderSchema } from "../data/schema";

const faqs = [
  {
    question: "Кой стои зад Vdiga?",
    answer:
      "Зад Vdiga стоят съоснователите Деан Дечев и Мариян Дечев и малък екип, който работи по продукта, настройката на AI асистентите, интеграциите и поддръжката след старта.",
  },
  {
    question: "Vdiga отделна фирма ли е?",
    answer:
      "На този етап Vdiga е продукт на Blast Off EOOD — юридическият оператор, който поема договорите, фактурирането и отговорността към клиентите.",
  },
  {
    question: "Как се внедрява Vdiga в един бизнес?",
    answer:
      "Започваме с преглед на реалните обаждания, въпроси и правила на бизнеса. След това настройваме асистента, свързваме нужните системи, тестваме основните и трудните сценарии и подобряваме поведението му преди и след старта.",
  },
  {
    question: "Кой преглежда съдържанието на сайта?",
    answer:
      "Всяка страница минава човешка редакция преди публикуване. Не използваме измислени статистики и отделяме ясно проверените факти от примерите и прогнозите.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="За Vdiga и екипа | AI рецепционист за бизнеса"
  description="Научете кой стои зад Vdiga, как разработваме AI рецепционисти за българския бизнес и коя компания носи юридическата отговорност."
  path="/za-nas/"
  schemas={[
    founderSchema(),
    breadcrumbSchema([
      { name: "Начало", href: "/" },
      { name: "За нас", href: "/za-nas/" },
    ]),
    faqSchema(faqs),
  ]}
>
  <section class="hero about-hero">
    <div class="container">
      <p class="eyebrow">за Vdiga</p>
      <h1>За Vdiga — AI рецепционист за българския бизнес</h1>
      <p class="answer-block">
        Vdiga разработва и внедрява AI телефонни асистенти, които приемат входящи обаждания, отговарят на въпроси, записват заявки и предават точна информация към екипа.
      </p>
      <p class="lead">
        Целта ни е конкретна: по-малко пропуснати клиенти и по-малко ръчна работа около телефона. Всеки асистент се настройва според услугите, правилата и системите на конкретния бизнес.
      </p>
      <div class="button-row hero-actions">
        <button class="btn btn-primary" type="button" data-play-demo aria-pressed="false">Чуйте разговор</button>
        <a class="btn btn-secondary" href={href("/kak-raboti/")}>Как работи Vdiga</a>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container about-intro">
      <div>
        <p class="eyebrow">нашият подход</p>
        <h2>Как изграждаме AI рецепционист, на когото бизнесът може да разчита?</h2>
      </div>
      <div class="about-principles">
        <article>
          <span>01</span>
          <h3>Изучаваме реалните обаждания</h3>
          <p>Уточняваме кой се обажда, какво пита, каква информация е необходима и кога разговорът трябва да бъде поет от човек.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Настройваме правилата и действията</h3>
          <p>Описваме услугите, честите въпроси, ограниченията и следващите стъпки. При нужда свързваме календара, CRM или друга използвана система.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Тестваме и подобряваме</h3>
          <p>Проверяваме обичайни, трудни и неочаквани сценарии. След старта анализираме разговорите и коригираме асистента според реалното му използване.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="founders-heading">
        <p class="eyebrow">съоснователи</p>
        <h2>Хората зад Vdiga</h2>
        <p>Продуктът се развива с общата работа на бизнес и технологична експертиза.</p>
      </div>
      <div class="founders-grid">
        <article class="founder-card">
          <div class="founder-mark" aria-hidden="true">ДД</div>
          <div class="founder-copy">
            <h3>{site.author.name}</h3>
            <p class="founder-role">{site.author.role}</p>
            <p>{site.author.bio}</p>
          </div>
        </article>
        <article class="founder-card">
          <div class="founder-mark" aria-hidden="true">МД</div>
          <div class="founder-copy">
            <h3>{site.coFounder.name}</h3>
            <p class="founder-role">{site.coFounder.role}</p>
            <p>{site.coFounder.bio}</p>
            <p class="founder-credential">AWS Certified Solutions Architect – Associate</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2 about-team">
      <div>
        <p class="eyebrow">екипът зад Vdiga</p>
        <h2>Директен контакт с хората, които изграждат продукта.</h2>
      </div>
      <div>
        <p class="lead">
          Зад Vdiga стоят съоснователите Деан Дечев и Мариян Дечев и малък екип с опит в дигиталните продукти, автоматизацията и практическото внедряване на AI.
        </p>
        <p>
          Не предаваме внедряването на анонимен външен екип. Работим директно с клиента — от първоначалния преглед на процеса до интеграцията, тестовете и подобренията след старта.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container legal-trust">
      <div>
        <p class="eyebrow">отговорност и прозрачност</p>
        <h2>Коя компания стои юридически зад Vdiga?</h2>
        <p>
          Vdiga е търговското име на продукта. На този етап договорите и фактурирането се извършват от {site.legalName}, което е юридическият оператор на услугата и носи отговорността към клиентите.
        </p>
      </div>
      <dl class="company-facts">
        <div><dt>Продукт</dt><dd>{site.brand}</dd></div>
        <div><dt>Юридически оператор</dt><dd>{site.legalName}</dd></div>
        <div><dt>Локация</dt><dd>{site.location}, България</dd></div>
        <div><dt>Контакт</dt><dd><a href={`tel:+359${site.salesPhone.replace(/\s/g, "").replace(/^0/, "")}`}>{site.salesPhone}</a></dd></div>
      </dl>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">чести въпроси</p>
        <h2>Въпроси за Vdiga, екипа и отговорността</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Чуйте Vdiga в реален разговор." text="След това можем да обсъдим кои обаждания да поеме и как да се свърже с процесите във вашия бизнес." />
</BaseLayout>
