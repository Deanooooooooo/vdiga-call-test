---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import { site } from "../data/site";
import { breadcrumbSchema, faqSchema, founderSchema } from "../data/schema";

const faqs = [
  {
    question: "Кой стои зад Vdiga?",
    answer:
      "Vdiga се развива от малък екип, ръководен от основателя Деан Дечев. Екипът работи по продукта, настройката на AI асистентите, интеграциите и поддръжката след старта.",
  },
  {
    question: "Vdiga отделна фирма ли е?",
    answer:
      "На този етап Vdiga е продукт на Blast Off EOOD — юридическият оператор, който поема договорите, фактурирането и отговорността към клиентите.",
  },
  {
    question: "Как се внедрява Vdiga в един бизнес?",
    answer:
      "Започваме с разговор за реалните обаждания и процеси. След това настройваме асистента, свързваме нужните системи, тестваме разговорите и подобряваме поведението му преди и след старта.",
  },
  {
    question: "Кой преглежда съдържанието на сайта?",
    answer:
      "Всяка страница минава човешка редакция преди публикуване. Не използваме измислени статистики и отделяме ясно проверените факти от примерите и прогнозите.",
  },
];
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<BaseLayout
  title="За Vdiga и екипа зад AI рецепциониста"
  description="Запознайте се с Vdiga, основателя Деан Дечев и екипа, който разработва и внедрява AI телефонни асистенти за българския бизнес."
  path="/za-nas/"
  schemas={[
    founderSchema(),
    breadcrumbSchema([
      { name: "Начало", href: "/" },
      { name: "За нас", href: "/za-nas/" },
    ]),
    faqSchema(faqs),
  ]}
>
  <section class="hero about-hero">
    <div class="container">
      <p class="eyebrow">за Vdiga</p>
      <h1>AI, който върши реална работа за бизнеса.</h1>
      <p class="answer-block">
        Vdiga създава AI телефонни асистенти, които отговарят на обаждания, разбират какво иска клиентът и изпълняват следващата стъпка — без бизнесът да променя начина си на работа.
      </p>
      <p class="lead">
        Не предлагаме просто глас зад телефона. Настройваме цял работещ процес: разговор, информация, действие, интеграция и проследяване.
      </p>
      <div class="button-row hero-actions">
        <button class="btn btn-primary" type="button" data-play-demo aria-pressed="false">Чуйте разговор</button>
        <a class="btn btn-secondary" href={href("/kak-raboti/")}>Как работи Vdiga</a>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container about-intro">
      <div>
        <p class="eyebrow">нашият подход</p>
        <h2>Започваме от разговора, не от технологията.</h2>
      </div>
      <div class="about-principles">
        <article>
          <span>01</span>
          <h3>Разбираме процеса</h3>
          <p>Първо изясняваме кой се обажда, какво пита и какво трябва да се случи след разговора.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Настройваме и тестваме</h3>
          <p>Изграждаме поведението на асистента с реални сценарии, изключения и ясни правила за прехвърляне към човек.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Подобряваме след старта</h3>
          <p>Следим как протичат разговорите и коригираме асистента според истинските въпроси на клиентите.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container founder-section">
      <div class="founder-mark" aria-hidden="true">ДД</div>
      <div class="founder-copy">
        <p class="eyebrow">основател</p>
        <h2>{site.author.name}</h2>
        <p class="founder-role">{site.author.role}</p>
        <p>{site.author.bio}</p>
      </div>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2 about-team">
      <div>
        <p class="eyebrow">екипът зад Vdiga</p>
        <h2>Малък екип с пряка отговорност.</h2>
      </div>
      <div>
        <p class="lead">
          Vdiga се развива от малък екип с опит в дигиталните продукти, автоматизацията и практическото внедряване на AI.
        </p>
        <p>
          Работим директно с бизнеса — от първия разговор и настройката на асистента до интеграцията, наблюдението и подобряването му след старта. Така клиентът знае кой отговаря за решението и към кого да се обърне.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container legal-trust">
      <div>
        <p class="eyebrow">отговорност и прозрачност</p>
        <h2>Vdiga е продукт с реален юридически оператор.</h2>
        <p>
          На този етап Vdiga се разработва и управлява от {site.legalName}. Дружеството поема договорите, фактурирането и отговорността към клиентите, докато Vdiga остава името на продукта и услугата.
        </p>
      </div>
      <dl class="company-facts">
        <div><dt>Продукт</dt><dd>{site.brand}</dd></div>
        <div><dt>Юридически оператор</dt><dd>{site.legalName}</dd></div>
        <div><dt>Локация</dt><dd>{site.location}, България</dd></div>
        <div><dt>Контакт</dt><dd><a href={`tel:+359${site.salesPhone.replace(/\s/g, "").replace(/^0/, "")}`}>{site.salesPhone}</a></dd></div>
      </dl>
    </div>
  </section>

  <section class="section band">
    <div class="container grid-2">
      <div>
        <p class="eyebrow">чести въпроси</p>
        <h2>Кой създава и поддържа Vdiga?</h2>
      </div>
      <FAQ items={faqs} />
    </div>
  </section>

  <CTA title="Първо чуйте как работи." text="След това ще обсъдим къде Vdiga може да помогне във вашия реален процес." />
</BaseLayout>
