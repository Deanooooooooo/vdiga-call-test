---
import { site } from "../data/site";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<header class="site-top">
  <div class="container nav">
    <a class="brand" href={href("/")} aria-label="Vdiga начало">
      <img class="brand-logo" src={href("/assets/vdiga-logo-nav-green-v.png?v=8f71ca30")} alt="Vdiga" width="320" height="123" />
    </a>
    <nav class="nav-links" aria-label="Основна навигация">
      {site.nav.map((item) => <a href={href(item.href)}>{item.label}</a>)}
    </nav>
    <div class="nav-actions">
      <a class="btn btn-primary nav-cta nav-phone" href={`tel:${site.salesPhone.replace(/\s/g, "")}`}>Обадете се: {site.salesPhone}</a>
    </div>
  </div>
</header>
