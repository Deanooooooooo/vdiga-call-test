---
import { site } from "../data/site";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<header class="site-top">
  <div class="container nav">
    <a class="brand" href={href("/")} aria-label="Vdiga начало">
      <span class="brand-mark">V</span>
      <span>Vdiga</span>
    </a>
    <nav class="nav-links" aria-label="Основна навигация">
      {site.nav.map((item) => <a href={href(item.href)}>{item.label}</a>)}
    </nav>
    <a class="btn btn-primary nav-cta" href={href("/demo")}>Чуйте демото</a>
  </div>
</header>
