---
import { site } from "../data/site";

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Чуйте AI рецепциониста, преди да говорим за внедряване.",
  text = "Vdiga трябва да мине най-простия тест: звучи ли достатъчно ясно, за да му поверите първото обаждане?",
} = Astro.props;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<section class="section-tight">
  <div class="container">
    <div class="cta-band">
      <div>
        <h2>{title}</h2>
        <p>{text}</p>
      </div>
      {
        site.demoPhone ? (
          <a class="btn btn-primary" href={`tel:${site.demoPhone}`}>Обадете се сега</a>
        ) : (
          <a class="btn btn-primary" href={href("/demo")}>{site.demoPhoneLabel}</a>
        )
      }
    </div>
  </div>
</section>
