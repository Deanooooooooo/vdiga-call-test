---
import { site } from "../data/site";

interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Чуйте AI рецепциониста, преди да говорим за внедряване.",
  text = "Vdiga трябва да мине най-простия тест: звучи ли достатъчно ясно, за да му поверите първото обаждане?",
} = Astro.props;
---

<section class="section-tight">
  <div class="container">
    <div class="cta-band">
      <div>
        <h2 style="font-size: clamp(1.5rem, 2.4vw, 2.35rem); margin-bottom: 8px;">{title}</h2>
        <p style="margin-bottom: 0;">{text}</p>
      </div>
      {
        site.demoPhone ? (
          <a class="btn btn-primary" href={`tel:${site.demoPhone}`}>Обадете се сега</a>
        ) : (
          <a class="btn btn-primary" href="/demo">{site.demoPhoneLabel}</a>
        )
      }
    </div>
  </div>
</section>
