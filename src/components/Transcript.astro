---
const lines = [
  { speaker: "Vdiga", text: "Кой ден и кой час ви е удобен?" },
  { speaker: "Клиент", text: "Имате ли час утре в 09:00?" },
  { speaker: "Vdiga", text: "Да, имаме свободен час утре в 09:00." },
  { speaker: "Клиент", text: "Да, запишете." },
];
---

<ul class="transcript" aria-label="Примерен разговор">
  {lines.map((line) => <li><strong>{line.speaker}:</strong> {line.text}</li>)}
</ul>
