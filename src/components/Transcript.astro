---
const lines = [
  { speaker: "Клиент", text: "Имате ли свободен час утре следобед?" },
  { speaker: "Vdiga", text: "Да, има час в 16:30 ч. За преглед ли е?" },
  { speaker: "Клиент", text: "Да, запишете ме за 16:30 ч." },
];
---

<ul class="transcript" aria-label="Примерен разговор">
  {lines.map((line) => <li><strong>{line.speaker}:</strong> {line.text}</li>)}
</ul>
