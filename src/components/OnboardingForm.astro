---
import { site } from "../data/site";
---

<section class="onboarding-panel" id="zayavka" aria-labelledby="onboarding-title">
  <div class="onboarding-inner">
  <div class="onboarding-copy">
    <p class="eyebrow">заявете разговор</p>
    <h2 id="onboarding-title">Не изпускайте следващия клиент.</h2>
    <p class="onboarding-lead">
      Оставете ни телефон. Ще ви се обадим, за да разберем какво губите с пропуснатите обаждания и как Vdiga може да ги поеме.
    </p>
    <ul class="onboarding-points" aria-label="Какво следва">
      <li>Говорите с човек от екипа ни</li>
      <li>Получавате цена за вашия бизнес</li>
      <li>Решавате след разговора</li>
    </ul>
    {site.salesPhone && (
      <div class="direct-call">
        <span class="direct-call-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M7.3 3.5 4.8 6c-.8.8-.9 2-.4 3 2.1 4.7 5.9 8.5 10.6 10.6 1 .5 2.2.3 3-.4l2.5-2.5-4-4-2.3 2.3c-2.2-1.2-4-3-5.2-5.2l2.3-2.3-4-4Z"/></svg>
        </span>
        <div>
          <strong>Не искате да чакате?</strong>
          <a href={`tel:${site.salesPhone}`}>Обадете ни се на {site.salesPhone}</a>
          <p>{site.salesHours}</p>
        </div>
      </div>
    )}
  </div>

  <form class="onboarding-form" data-onboarding-form novalidate>
    <div class="form-heading">
      <span>Нека ви се обадим</span>
      <small>Отнема около минута</small>
    </div>

    <div class="form-grid">
      <label>
        <span>Вашето име</span>
        <input type="text" name="contact_name" autocomplete="name" placeholder="Име и фамилия" required />
      </label>
      <label>
        <span>Име на бизнеса</span>
        <input type="text" name="business_name" autocomplete="organization" placeholder="Например Studio Forma" required />
      </label>
      <label>
        <span>Телефон</span>
        <input type="tel" name="phone" autocomplete="tel" inputmode="tel" placeholder="+359 88 123 4567" required />
      </label>
      <label>
        <span>Имейл</span>
        <input type="text" name="email" autocomplete="email" inputmode="email" placeholder="name@business.bg" required />
      </label>
      <label class="form-field-wide">
        <span>За какво ви звънят клиентите?</span>
        <select name="primary_need" required>
          <option value="" selected disabled>Изберете най-важното</option>
          <option value="appointments">Записване на часове</option>
          <option value="reservations">Приемане на резервации</option>
          <option value="orders">Приемане на поръчки</option>
          <option value="enquiries">Запитвания и огледи</option>
          <option value="other">Друго</option>
        </select>
      </label>
      <label class="form-field-wide">
        <span>Кога изпускате най-много обаждания? <small>по желание</small></span>
        <textarea name="current_call_problem" rows="3" placeholder="Например: когато сме с клиенти или след работно време"></textarea>
      </label>
    </div>

    <label class="consent-row">
      <input type="checkbox" name="callback_consent" value="yes" required />
      <span>Съгласен съм Vdiga да се свърже с мен по тази заявка.</span>
    </label>

    <button class="btn btn-primary form-submit" type="submit">Искам да ми се обадите</button>
    <p class="form-note">Няма плащане или абонамент. Първо разговаряме.</p>
    <p class="form-status" data-form-status aria-live="polite"></p>
  </form>
  </div>
</section>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.querySelector<HTMLFormElement>("[data-onboarding-form]");
  const status = form?.querySelector<HTMLElement>("[data-form-status]");
  const submitButton = form?.querySelector<HTMLButtonElement>("[type='submit']");
  const formHeading = form?.querySelector<HTMLElement>(".form-heading span");
  let selectedPlan: string | null = null;
  let selectedBillingPeriod: "monthly" | "annual" | null = null;
  const primaryNeedLabels: Record<string, string> = {
    appointments: "Записване на часове",
    reservations: "Приемане на резервации",
    orders: "Приемане на поръчки",
    enquiries: "Запитвания и огледи",
    other: "Друго",
  };
  const primaryNeeds = new Set(Object.keys(primaryNeedLabels));

  const setStatus = (message: string, state: "idle" | "success" | "error" = "idle") => {
    if (!status) return;
    status.textContent = message;
    status.classList.toggle("is-success", state === "success");
    status.classList.toggle("is-error", state === "error");
  };

  const cleanText = (value: FormDataEntryValue | null) => String(value || "").trim();
  const isValidBulgarianPhone = (value: string) => {
    const digits = value.replace(/\D/g, "");
    return /^0\d{9}$/.test(digits) || /^359\d{9}$/.test(digits);
  };
  const isPlainAsciiEmail = (value: string) => {
    const domain = value.split("@").pop() || "";
    const hasPunycodeDomainLabel = domain
      .toLowerCase()
      .split(".")
      .some((label) => label.startsWith("xn--"));
    return /^[\x00-\x7F]+$/.test(value) && !hasPunycodeDomainLabel;
  };
  const isValidEmailAddress = (value: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
  const getActiveBillingPeriod = () => {
    const activeBilling = document.querySelector<HTMLButtonElement>("[data-billing].is-active");
    return activeBilling?.dataset.billing === "annual" ? "annual" : "monthly";
  };

  document.querySelectorAll<HTMLAnchorElement>("[data-plan]").forEach((link) => {
    link.addEventListener("click", () => {
      const plan = link.dataset.plan || "";
      selectedPlan = plan || null;
      selectedBillingPeriod = selectedPlan ? getActiveBillingPeriod() : null;
      if (formHeading) formHeading.textContent = plan === "500+ минути" ? "Нека обсъдим обема ви" : `План ${plan}`;
    });
  });

  document.addEventListener("vdiga:billing-change", ((event: CustomEvent<{ period: string }>) => {
    if (!selectedPlan) return;
    selectedBillingPeriod = event.detail.period === "annual" ? "annual" : "monthly";
  }) as EventListener);

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const email = cleanText(formData.get("email"));

    if (!isPlainAsciiEmail(email)) {
      setStatus("Моля, използвайте само латински букви в имейла.", "error");
      return;
    }

    if (!isValidEmailAddress(email)) {
      setStatus("Въведете валиден имейл адрес.", "error");
      return;
    }

    if (!form.checkValidity()) {
      form.reportValidity();
      setStatus("Проверете задължителните полета.", "error");
      return;
    }

    if (!supabase) {
      setStatus("Връзката към базата още не е конфигурирана.", "error");
      return;
    }

    const primaryNeed = cleanText(formData.get("primary_need"));
    const callbackConsent = formData.get("callback_consent") === "yes";
    const phone = cleanText(formData.get("phone"));

    if (!primaryNeeds.has(primaryNeed)) {
      setStatus("Изберете за какво най-често звънят клиентите.", "error");
      return;
    }

    if (!callbackConsent) {
      setStatus("Потвърдете, че можем да се свържем с вас.", "error");
      return;
    }

    if (!isValidBulgarianPhone(phone)) {
      setStatus("Въведете валиден български телефон, например 089 123 4567 или +359 89 123 4567.", "error");
      return;
    }

    const currentCallProblem = cleanText(formData.get("current_call_problem"));
    const payload = {
      contact_name: cleanText(formData.get("contact_name")),
      business_name: cleanText(formData.get("business_name")),
      phone,
      email,
      primary_need: primaryNeed,
      primary_need_label: primaryNeedLabels[primaryNeed],
      current_call_problem: currentCallProblem || null,
      callback_consent: callbackConsent,
      selected_plan: selectedPlan,
      billing_period: selectedPlan ? selectedBillingPeriod : null,
      source_path: window.location.pathname,
      user_agent: navigator.userAgent,
      metadata: {
        referrer: document.referrer || null,
      },
    };

    setStatus("Изпращаме заявката...");
    if (submitButton) submitButton.disabled = true;

    const { error } = await supabase.from("onboarding_requests").insert(payload);

    if (error) {
      const errorMessage = String(error.message || "");
      const isDuplicateThrottle = errorMessage.includes("Duplicate onboarding request throttled");
      setStatus(
        isDuplicateThrottle
          ? "Вече получихме заявка с този имейл или телефон. Ще се свържем с вас скоро. Ако искате да коригирате данните, обадете ни се директно."
          : "Не успяхме да изпратим заявката. Опитайте пак или ни се обадете директно.",
        "error",
      );
      if (submitButton) submitButton.disabled = false;
      return;
    }

    form.reset();
    selectedPlan = null;
    selectedBillingPeriod = null;
    if (formHeading) formHeading.textContent = "Нека ви се обадим";
    setStatus("Получихме заявката. Ще се свържем с вас.", "success");
    if (submitButton) submitButton.disabled = false;
  });
</script>
