---
import WaveformPlayer from "./WaveformPlayer.astro";
import Transcript from "./Transcript.astro";
import { site } from "../data/site";
---

<article class="call-card" aria-label="Демо обаждане към Vdiga">
  <div class="call-card-inner">
    <p class="eyebrow" style="margin-bottom: 8px;">на линия сега</p>
    {
      site.demoPhone ? (
        <a class="demo-number" href={`tel:${site.demoPhone}`}>{site.demoPhone}</a>
      ) : (
        <strong class="demo-number muted-number">Демо номерът се подготвя</strong>
      )
    }
    <div class="button-row">
      {
        site.demoPhone ? (
          <a class="btn btn-primary" href={`tel:${site.demoPhone}`}>Обади се — вдига веднага</a>
        ) : (
          <a class="btn btn-primary" href="/demo">Вижте демо потока</a>
        )
      }
      <a class="btn btn-secondary" href="/kak-raboti">Вижте потока</a>
    </div>
    <ul class="call-meta">
      <li>24/7 отговор</li>
      <li>записване на час</li>
      <li>обобщение след разговор</li>
    </ul>
  </div>
  {site.demoPhone ? <WaveformPlayer /> : <div class="static-transcript"><Transcript /></div>}
</article>
