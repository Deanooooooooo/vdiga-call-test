---
import WaveformPlayer from "./WaveformPlayer.astro";
import { site } from "../data/site";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<article class="call-card" aria-label="Демо обаждане към Vdiga">
  <div class="phone-top">
    <span></span>
    <strong>Входящ разговор</strong>
    <span class="live-dot">на линия</span>
  </div>
  <div class="call-card-inner">
    <p class="eyebrow compact">примерно обаждане</p>
    {
      site.demoPhone ? (
        <a class="demo-number" href={`tel:${site.demoPhone}`}>{site.demoPhone}</a>
      ) : (
        <strong class="demo-number muted-number">Как звучи Vdiga</strong>
      )
    }
    <p class="card-copy">Клиент звъни. Vdiga пита за услугата, намира свободен час и връща кратко обобщение към екипа.</p>
    <div class="button-row card-actions">
      <a class="btn btn-primary" href={href("/demo")}>Чуйте демото</a>
      <a class="btn btn-ghost-light" href={href("/kak-raboti")}>Как работи</a>
    </div>
    <ul class="call-meta">
      <li>отговаря веднага</li>
      <li>календар</li>
      <li>SMS обобщение</li>
    </ul>
  </div>
  <WaveformPlayer />
</article>
