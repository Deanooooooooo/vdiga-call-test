---
import WaveformPlayer from "./WaveformPlayer.astro";
import { site } from "../data/site";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<article class="call-card" aria-label="Демо обаждане към Vdiga">
  <div class="call-card-inner">
    {
      site.demoPhone ? (
        <a class="demo-number" href={`tel:${site.demoPhone}`}>{site.demoPhone}</a>
      ) : (
        <strong class="demo-number muted-number">Примерно обаждане</strong>
      )
    }
    <div class="button-row card-actions">
      <button class="btn btn-primary" type="button" data-play-demo aria-pressed="false">Чуйте разговора</button>
      <a class="btn btn-ghost-light" href={href("/kak-raboti/")}>Как работи</a>
    </div>
  </div>
  <WaveformPlayer />
</article>
