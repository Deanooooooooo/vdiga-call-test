---
import { site } from "../data/site";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<div class="pricing-grid">
  {
    site.pricing.map((tier, index) => (
      <article class:list={["price-card", index === 1 && "featured"]}>
        <h3>{tier.name}</h3>
        <p>{tier.note}</p>
        <div class="price">
          {tier.price} <small>{tier.suffix}</small>
        </div>
        <p>Без ДДС. Месечно, без дълго обвързване.</p>
        <ul class="split-list">
          {tier.features.map((feature) => <li>{feature}</li>)}
        </ul>
        <a class:list={["btn", index === 1 ? "btn-primary" : "btn-outline"]} href={href("/demo")}>{tier.cta}</a>
      </article>
    ))
  }
</div>
