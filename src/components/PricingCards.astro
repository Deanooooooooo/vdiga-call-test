---
import { site } from "../data/site";
---

<div class="pricing-grid">
  {
    site.pricing.map((tier, index) => (
      <article class:list={["price-card", index === 1 && "featured"]}>
        <h3>{tier.name}</h3>
        <p>{tier.note}</p>
        <div class="price">
          {tier.price} <small>{tier.suffix}</small>
        </div>
        <p>Без ДДС. Месечен абонамент, без дълъг договор.</p>
        <ul class="split-list">
          {tier.features.map((feature) => <li>{feature}</li>)}
        </ul>
      </article>
    ))
  }
</div>
