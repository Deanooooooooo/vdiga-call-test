---
import { site } from "../data/site";

interface Props {
  datePublished: string;
  dateModified: string;
}

const { datePublished, dateModified } = Astro.props;
const formatDate = (value: string) =>
  new Intl.DateTimeFormat("bg-BG", {
    day: "numeric",
    month: "long",
    year: "numeric",
  }).format(new Date(`${value}T12:00:00+03:00`));
---

<aside class="article-meta" aria-label="Информация за страницата">
  <div class="avatar">D</div>
  <div>
    <strong>{site.author.name}</strong>
    <p>{site.author.role}. {site.author.bio}</p>
    <span>Публикувано: {formatDate(datePublished)} · Обновено: {formatDate(dateModified)}</span>
  </div>
</aside>
