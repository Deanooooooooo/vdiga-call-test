---
import { site } from "../data/site";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const href = (path: string) => `${basePath}${path}`;
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <a class="brand" href={href("/")}>
        <img class="brand-logo" src={href("/assets/vdiga-logo-nav-green-v.png?v=8f71ca30")} alt="Vdiga" width="320" height="123" />
      </a>
      <p style="max-width: 620px; margin: 18px 0 0;">
        {site.descriptor}
      </p>
      <div class="trust-strip">{site.legalName} · ЕИК {site.companyId} · София</div>
    </div>
    <div class="footer-links">
      {site.nav.map((item) => <a href={href(item.href)}>{item.label}</a>)}
      <a href={href("/politika-za-poveritelnost/")}>Поверителност</a>
    </div>
  </div>
</footer>
